---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import AdminLogin from '../../components/AdminLogin.astro';
---

<Layout title="تنبيهات الأقساط">
    <div id="auth-loading-message" class="auth-container">
        <p>جارٍ التحقق من صلاحيات الدخول...</p>
    </div>

    <div id="admin-login-container" class="auth-container" style="display: none;">
      <AdminLogin />
    </div>

    <main id="page-content" style="display: none;">
        <div class="notifications-container">
            <div class="notifications-header">
                <h1 id="project-name-header">تنبيهات الأقساط للمشروع</h1>
                <a id="back-link" href="#" class="btn btn-secondary">العودة للعقود</a>
            </div>

            <div id="loader">جاري تحميل التنبيهات...</div>
            <div id="error-display" class="message-card" style="display: none;"></div>

            <div id="notifications-content" style="display: none;">
                <!-- Overdue Installments -->
                <div class="notification-section">
                    <h2>أقساط متأخرة</h2>
                    <div id="overdue-installments-list" class="installments-list">
                        <!-- Overdue items will be inserted here -->
                    </div>
                    <p id="no-overdue-message" class="empty-message" style="display: none;">لا توجد أقساط متأخرة حاليًا.</p>
                </div>

                <!-- Upcoming Installments -->
                <div class="notification-section">
                    <h2>أقساط تستحق خلال 7 أيام</h2>
                    <div id="upcoming-installments-list" class="installments-list">
                        <!-- Upcoming items will be inserted here -->
                    </div>
                    <p id="no-upcoming-message" class="empty-message" style="display: none;">لا توجد أقساط تستحق قريبًا.</p>
                </div>
            </div>
        </div>
    </main>
</Layout>

<style is:global>
    :root {
        --primary-color: #2c3e50;
        --secondary-color: #7f8c8d;
        --danger-color: #c0392b;
        --warning-color: #f39c12;
        --border-color: #e0e0e0;
        --shadow: 0 4px 12px rgba(0,0,0,0.06);
    }
    .auth-container { display: flex; align-items: center; justify-content: center; min-height: 100vh; text-align: center; font-family: 'Cairo', sans-serif; }
    main#page-content { padding: 2rem 1rem; background-color: #f7f9fc; min-height: 100vh; direction: rtl; font-family: 'Cairo', sans-serif; }
    .notifications-container { max-width: 950px; margin: 0 auto; }
    .notifications-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--border-color); padding-bottom: 1.5rem; margin-bottom: 2rem; }
    .btn { padding: 0.7rem 1.4rem; border-radius: 8px; border: none; font-weight: 600; cursor: pointer; transition: 0.3s; color: white; text-decoration: none; display: inline-block; font-family: inherit; }
    .btn-secondary { background-color: var(--secondary-color); }
    
    #loader, .message-card, .empty-message { text-align: center; padding: 2rem; background: white; border-radius: 12px; box-shadow: var(--shadow); color: var(--secondary-color); }
    .notification-section { background: white; padding: 2rem; border-radius: 12px; box-shadow: var(--shadow); margin-bottom: 2rem; }
    .notification-section h2 { border-bottom: 2px solid #eee; padding-bottom: 1rem; margin-bottom: 1.5rem; color: var(--primary-color); }
    
    .installments-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
    .installment-card { display: block; text-decoration: none; color: inherit; padding: 1.5rem; border-radius: 8px; border: 1px solid #eee; transition: 0.3s; border-right-width: 5px; }
    .installment-card:hover { transform: translateY(-3px); box-shadow: 0 6px 15px rgba(0,0,0,0.1); }
    .overdue { border-right-color: var(--danger-color); }
    .upcoming { border-right-color: var(--warning-color); }
    
    .card-header { font-weight: 700; font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--primary-color); }
    .status-text { font-weight: 700; }
    .overdue .status-text { color: var(--danger-color); }
    .upcoming .status-text { color: var(--warning-color); }
</style>

<script>
  import { checkAuth, logout } from '../../lib/auth.js';
  
  const formatCurrency = (num) => (num || 0).toLocaleString('ar-EG', { style: 'currency', currency: 'EGP' });
  const formatDate = (val) => new Date(val).toLocaleDateString('ar-EG', { year: 'numeric', month: 'long', day: 'numeric' });

  document.addEventListener('DOMContentLoaded', async () => {
      const authLoadingMessage = document.getElementById('auth-loading-message');
      const loginContainer = document.getElementById('admin-login-container');
      const pageContent = document.getElementById('page-content');

      const user = await checkAuth();
      if(authLoadingMessage) authLoadingMessage.style.display = 'none';

      if (user && user.role === 'admin') {
          if(pageContent) pageContent.style.display = 'block';
          if(loginContainer) loginContainer.style.display = 'none';
          initializeApp();
      } else {
          if(loginContainer) loginContainer.style.display = 'block';
          if(pageContent) pageContent.style.display = 'none';
      }
  });

  async function initializeApp() {
      const urlParams = new URLSearchParams(window.location.search);
      const projectId = urlParams.get('projectId');
      if (!projectId) return;

      (document.getElementById('back-link') as HTMLAnchorElement).href = `/crs/project-installments?projectId=${projectId}`;

      try {
          const projectRes = await fetch(`/api/project-details/${projectId}`);
          const project = await projectRes.json();
          document.getElementById('project-name-header').textContent = `تنبيهات أقساط: ${project.projectName}`;

          const res = await fetch(`/api/installments?projectId=${projectId}`);
          const installments = await res.json();

          const today = new Date();
          today.setHours(0,0,0,0);
          const limit = new Date();
          limit.setDate(today.getDate() + 7);

          const overdue = installments.filter(i => i.status === 'pending' && new Date(i.dueDate) < today);
          const upcoming = installments.filter(i => i.status === 'pending' && new Date(i.dueDate) >= today && new Date(i.dueDate) <= limit);

          renderList('overdue', overdue, projectId);
          renderList('upcoming', upcoming, projectId);

          document.getElementById('loader').style.display = 'none';
          document.getElementById('notifications-content').style.display = 'block';
      } catch (e) {
          console.error(e);
      }
  }

  function renderList(type, items, projectId) {
      const container = document.getElementById(`${type}-installments-list`);
      const emptyMsg = document.getElementById(`no-${type}-message`);
      if(!container || !emptyMsg) return;

      if (items.length === 0) {
          emptyMsg.style.display = 'block';
          container.style.display = 'none';
          return;
      }

      emptyMsg.style.display = 'none';
      container.style.display = 'grid';
      
      const today = new Date();
      today.setHours(0,0,0,0);
      
      container.innerHTML = items.map(item => {
          const dueDate = new Date(item.dueDate);
          const diffTime = dueDate - today;
          const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
          
          let statusText = '';
          let statusDetails = '';
          
          if (type === 'overdue') {
              const overdueDays = Math.abs(diffDays);
              if (overdueDays === 1) {
                  statusText = 'متأخر يوم';
                  statusDetails = 'متأخر يوم واحد';
              } else if (overdueDays === 2) {
                  statusText = 'متأخر يومين';
                  statusDetails = 'متأخر يومين';
              } else if (overdueDays === 3) {
                  statusText = 'متأخر 3 أيام';
                  statusDetails = 'متأخر 3 أيام';
              } else {
                  statusText = `متأخر ${overdueDays} يوم`;
                  statusDetails = `متأخر ${overdueDays} يوم`;
              }
          } else {
              if (diffDays === 0) {
                  statusText = 'يستحق اليوم';
                  statusDetails = 'يستحق اليوم';
              } else if (diffDays === 1) {
                  statusText = 'يستحق غداً';
                  statusDetails = 'يستحق خلال يوم';
              } else if (diffDays === 2) {
                  statusText = 'يستحق بعد يومين';
                  statusDetails = 'يستحق خلال يومين';
              } else if (diffDays === 3) {
                  statusText = 'يستحق بعد 3 أيام';
                  statusDetails = 'يستحق خلال 3 أيام';
              } else if (diffDays <= 7) {
                  statusText = `يستحق خلال ${diffDays} أيام`;
                  statusDetails = `يستحق خلال ${diffDays} أيام`;
              } else {
                  statusText = `يستحق خلال ${diffDays} يوم`;
                  statusDetails = `يستحق خلال ${diffDays} يوم`;
              }
          }
          
          return `
              <a href="/crs/contract-details?projectId=${projectId}&customerName=${encodeURIComponent(item.customerName)}" class="installment-card ${type}">
                  <div class="card-header">${item.customerName}</div>
                  <div class="card-details">
                      <p><strong>المبلغ:</strong> ${formatCurrency(item.installmentAmount)}</p>
                      <p><strong>التاريخ:</strong> ${formatDate(item.dueDate)}</p>
                      <p class="status-text">${statusDetails}</p>
                  </div>
              </a>
          `;
      }).join('');
  }
</script>
