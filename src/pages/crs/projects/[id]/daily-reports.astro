---
export const prerender = false;
import Layout from '../../../../layouts/Layout.astro';
import AdminLogin from '../../../../components/AdminLogin.astro';
import prisma from "../../../../lib/prisma";

const { id } = Astro.params;
if (!id) return Astro.redirect('/404');

let project = null;
let dailyReports = [];
let feedback = { message: '', type: '' };

// Auth & Data Fetching
try {
    const projectDoc = await prisma.project.findUnique({ where: { id: id } });
    if (!projectDoc) return Astro.redirect('/404');
    project = projectDoc;

    // Mark as read
    await prisma.dailyReport.updateMany({
        where: { projectId: id, isRead: false },
        data: { isRead: true }
    });

    // Handle Actions
    const url = new URL(Astro.request.url);
    const deleteId = url.searchParams.get('delete');
    if (deleteId) {
        await prisma.dailyReport.delete({ where: { id: deleteId } });
        return Astro.redirect(`/crs/projects/${id}/daily-reports?feedback=deleted`);
    }

    if (Astro.request.method === 'POST') {
        const formData = await Astro.request.formData();
        const reportId = formData.get('reportId')?.toString();
        const content = formData.get('content')?.toString() || '';
        const notes = formData.get('notes')?.toString() || '';

        await prisma.dailyReport.update({
            where: { id: reportId },
            data: { content, notes }
        });
        return Astro.redirect(`/crs/projects/${id}/daily-reports?feedback=updated`);
    }

    // Feedback
    const fb = url.searchParams.get('feedback');
    if (fb === 'deleted') feedback = { message: 'تم حذف التقرير اليومي.', type: 'success' };
    if (fb === 'updated') feedback = { message: 'تم تحديث التقرير اليومي.', type: 'success' };

    // Fetch Reports
    dailyReports = await prisma.dailyReport.findMany({
        where: { projectId: id },
        orderBy: { createdAt: 'desc' }
    });

} catch (e) {
    console.error(e);
}

const formatDate = (d) => new Date(d).toLocaleDateString('ar-EG', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' });
---

<Layout title={`التقارير اليومية: ${project?.projectName}`}>
    <div id="auth-loading-message" class="auth-container"><p>جارٍ التحقق...</p></div>
    <div id="admin-login-container" class="auth-container" style="display: none;"><AdminLogin /></div>

    <main id="page-content" style="display: none;">
        <div class="container">
            <header class="page-header">
                <div>
                    <h1>التقارير اليومية لمشروع: {project?.projectName}</h1>
                    <p>عرض تفاصيل سير العمل اليومية.</p>
                </div>
                <div class="header-actions">
                    <a href={`/crs/projects/${id}`} class="btn btn-secondary">العودة</a>
                    <button id="logout-button" class="btn btn-danger">خروج</button>
                </div>
            </header>

            {feedback.message && <div class={`alert ${feedback.type}`}>{feedback.message}</div>}

            <div class="reports-list">
                {dailyReports.length === 0 ? (
                    <div class="empty-state">لا توجد تقارير يومية حتى الآن.</div>
                ) : (
                    dailyReports.map(report => (
                        <article class="report-card" data-id={report.id}>
                            <div class="card-meta">
                                <span>{report.supervisorName}</span>
                                <time>{formatDate(report.createdAt)}</time>
                            </div>
                            
                            <div class="view-mode">
                                <div class="report-content">
                                    <h4>محتوى التقرير:</h4>
                                    <p>{report.content}</p>
                                </div>
                                {report.notes && (
                                    <div class="report-notes">
                                        <h4>ملاحظات:</h4>
                                        <p>{report.notes}</p>
                                    </div>
                                )}
                                {report.imageUrls && (report.imageUrls as string[]).length > 0 && (
                                    <div class="report-images">
                                        <h4>الصور المرفقة:</h4>
                                        <div class="gallery">
                                            {(report.imageUrls as string[]).map(url => (
                                                <a href={url} target="_blank"><img src={url} alt="مرفق" /></a>
                                            ))}
                                        </div>
                                    </div>
                                )}
                                <div class="card-actions">
                                    <button class="btn-action btn-edit-report"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg> تعديل</button>
                                    <button class="btn-action btn-delete-report" data-id={report.id}><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg> حذف</button>
                                </div>
                            </div>

                            <form method="POST" class="edit-mode" style="display: none;">
                                <input type="hidden" name="reportId" value={report.id} />
                                <div class="field">
                                    <label>محتوى التقرير:</label>
                                    <textarea name="content" required>{report.content}</textarea>
                                </div>
                                <div class="field">
                                    <label>ملاحظات:</label>
                                    <textarea name="notes">{report.notes}</textarea>
                                </div>
                                <div class="edit-actions">
                                    <button type="button" class="btn-action btn-cancel-edit"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg> إلغاء</button>
                                    <button type="submit" class="btn-action btn-save-edit"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg> حفظ التعديلات</button>
                                </div>
                            </form>
                        </article>
                    ))
                )}
            </div>
        </div>
            <!-- Delete Confirmation Modal -->
        <div id="delete-modal" class="modal-overlay">
            <div class="modal-box">
                <h3>تأكيد الحذف</h3>
                <p>هل أنت متأكد من حذف هذا التقرير اليومي؟ لا يمكن التراجع عن هذا الإجراء.</p>
                <div class="modal-actions">
                    <button id="cancel-delete" class="btn-action btn-cancel-edit">إلغاء</button>
                    <button id="confirm-delete" class="btn-action btn-confirm-delete">تأكيد الحذف</button>
                </div>
            </div>
        </div>
    </main>
</Layout>

<script>
    import { checkAuth, logout } from '../../../../lib/auth.js';

    document.addEventListener('DOMContentLoaded', async () => {
        const user = await checkAuth();
        document.getElementById('auth-loading-message').style.display = 'none';

        if (user && user.role === 'admin') {
            document.getElementById('page-content').style.display = 'block';
            initApp();
        } else {
            document.getElementById('admin-login-container').style.display = 'block';
        }
    });

    function initApp() {
        document.getElementById('logout-button')?.addEventListener('click', async () => {
            await logout(); window.location.reload();
        });

        let deleteId = null;
        const deleteModal = document.getElementById('delete-modal');
        const cancelDeleteBtn = document.getElementById('cancel-delete');
        const confirmDeleteBtn = document.getElementById('confirm-delete');

        function showModal() { deleteModal.classList.add('visible'); document.body.style.overflow = 'hidden'; }
        function hideModal() { deleteModal.classList.remove('visible'); document.body.style.overflow = ''; deleteId = null; }

        cancelDeleteBtn?.addEventListener('click', hideModal);
        deleteModal?.addEventListener('click', (e) => { if (e.target === deleteModal) hideModal(); });
        confirmDeleteBtn?.addEventListener('click', () => {
            if (deleteId) {
                const url = new URL(window.location.href);
                url.searchParams.set('delete', deleteId);
                window.location.href = url.toString();
            }
        });

        document.querySelectorAll('.btn-edit-report').forEach(btn => {
            btn.addEventListener('click', () => {
                const card = btn.closest('.report-card');
                card.querySelector('.view-mode').style.display = 'none';
                card.querySelector('.edit-mode').style.display = 'block';
            });
        });

        document.querySelectorAll('.btn-cancel-edit').forEach(btn => {
            btn.addEventListener('click', () => {
                const card = btn.closest('.report-card');
                if (card) {
                    card.querySelector('.edit-mode').style.display = 'none';
                    card.querySelector('.view-mode').style.display = 'block';
                }
            });
        });

        document.querySelectorAll('.btn-delete-report').forEach(btn => {
            btn.addEventListener('click', () => {
                deleteId = (btn as any).dataset.id;
                showModal();
            });
        });
    }
</script>

<style is:global>
    :root { --primary: #2c3e50; --border: #e8e8e8; --shadow: 0 4px 12px rgba(0,0,0,0.05); }
    .auth-container { display: flex; align-items: center; justify-content: center; min-height: 100vh; font-family: 'Cairo', sans-serif; }
    main#page-content { direction: rtl; font-family: 'Cairo', sans-serif; background: #f4f6f8; min-height: 100vh; padding: 2rem; }
    .container { max-width: 1000px; margin: 0 auto; }
    .page-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--border); padding-bottom: 1.5rem; margin-bottom: 2rem; }
    .page-header h1 { font-size: 1.6rem; color: var(--primary); margin: 0; }
    .page-header p { color: #888; margin: 0.3rem 0 0; font-size: 0.95rem; }
    .header-actions { display: flex; gap: 0.5rem; align-items: center; }

    .report-card { background: white; border-radius: 12px; box-shadow: var(--shadow); margin-bottom: 1.5rem; padding: 1.5rem; border: 1px solid var(--border); transition: box-shadow 0.2s; }
    .report-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.08); }
    .card-meta { display: flex; justify-content: space-between; font-size: 0.9rem; color: #888; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid #f0f0f0; }
    .report-content, .report-notes, .report-images { margin-bottom: 1.2rem; }
    h4 { margin-bottom: 0.5rem; color: var(--primary); font-size: 1rem; }
    p { white-space: pre-wrap; line-height: 1.8; color: #444; }
    .gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 0.75rem; }
    .gallery img { width: 100%; height: 120px; object-fit: cover; border-radius: 8px; border: 1px solid #eee; transition: transform 0.2s; }
    .gallery img:hover { transform: scale(1.05); }

    .btn { padding: 0.5rem 1rem; border-radius: 8px; cursor: pointer; border: none; font-weight: 600; font-family: inherit; font-size: 0.9rem; transition: all 0.2s; text-decoration: none; display: inline-block; }
    .btn-secondary { background: #eee; color: #555; }
    .btn-secondary:hover { background: #ddd; }
    .btn-danger { background: #e74c3c; color: white; }
    .btn-danger:hover { background: #c0392b; }

    /* Action Buttons */
    .card-actions { display: flex; gap: 0.75rem; margin-top: 1.2rem; padding-top: 1rem; border-top: 1px solid #f0f0f0; }
    .btn-action { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5rem 1rem; border-radius: 8px; border: none; cursor: pointer; font-family: inherit; font-size: 0.85rem; font-weight: 600; transition: all 0.2s ease; }
    .btn-action svg { flex-shrink: 0; }

    .btn-edit-report { background: #ebf5fb; color: #2980b9; border: 1px solid #d4e6f1; }
    .btn-edit-report:hover { background: #d4e6f1; color: #1a5276; transform: translateY(-1px); box-shadow: 0 2px 8px rgba(41, 128, 185, 0.15); }

    .btn-delete-report { background: #fdedec; color: #c0392b; border: 1px solid #f5c6cb; }
    .btn-delete-report:hover { background: #f5c6cb; color: #922b21; transform: translateY(-1px); box-shadow: 0 2px 8px rgba(192, 57, 43, 0.15); }

    /* Edit Mode */
    .edit-mode { background: #fafcff; border-radius: 10px; padding: 1.5rem; border: 1px dashed #b0c4de; }
    .edit-mode .field { margin-bottom: 1.2rem; }
    .edit-mode label { display: block; margin-bottom: 0.5rem; font-weight: 700; color: var(--primary); font-size: 0.95rem; }
    .edit-mode textarea { width: 100%; min-height: 100px; padding: 0.75rem; border: 1px solid #d0d0d0; border-radius: 8px; font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s, box-shadow 0.2s; resize: vertical; }
    .edit-mode textarea:focus { outline: none; border-color: #2980b9; box-shadow: 0 0 0 3px rgba(41, 128, 185, 0.15); }
    .edit-actions { display: flex; gap: 0.75rem; margin-top: 1rem; justify-content: flex-end; }

    .btn-cancel-edit { background: #f0f0f0; color: #666; border: 1px solid #ddd; }
    .btn-cancel-edit:hover { background: #e0e0e0; color: #333; }

    .btn-save-edit { background: #27ae60; color: white; border: 1px solid #219a52; }
    .btn-save-edit:hover { background: #219a52; transform: translateY(-1px); box-shadow: 0 2px 8px rgba(39, 174, 96, 0.25); }

    .btn-confirm-delete { background: #e74c3c; color: white; border: 1px solid #c0392b; }
    .btn-confirm-delete:hover { background: #c0392b; }

    /* Modal */
    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: none; align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(3px); }
    .modal-overlay.visible { display: flex; }
    .modal-box { background: white; border-radius: 14px; padding: 2rem; width: 90%; max-width: 450px; box-shadow: 0 20px 50px rgba(0,0,0,0.15); text-align: center; }
    .modal-box h3 { color: #c0392b; margin-bottom: 1rem; font-size: 1.3rem; }
    .modal-box p { color: #555; line-height: 1.8; margin-bottom: 1.5rem; }
    .modal-actions { display: flex; gap: 0.75rem; justify-content: center; }
    .modal-actions .btn-action { min-width: 120px; justify-content: center; }

    /* Alert */
    .alert { padding: 1rem; border-radius: 10px; margin-bottom: 1.5rem; text-align: center; font-weight: 600; }
    .alert.success { background: #e8f8ef; color: #1e8449; border: 1px solid #a9dfbf; }

    .empty-state { text-align: center; padding: 3rem; color: #999; font-size: 1.1rem; background: white; border-radius: 12px; box-shadow: var(--shadow); }

    @media (max-width: 768px) {
        .page-header { flex-direction: column; gap: 1rem; text-align: center; }
        .header-actions { justify-content: center; }
        .card-actions { flex-direction: column; align-items: stretch; }
        .card-actions .btn-action { justify-content: center; }
        .edit-actions { flex-direction: column; align-items: stretch; }
        .edit-actions .btn-action { justify-content: center; }
        .modal-actions { flex-direction: column; }
    }
</style>