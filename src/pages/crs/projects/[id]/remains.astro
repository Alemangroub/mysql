---
import Layout from '../../../../layouts/Layout.astro';
import { db } from "../../../../firebase/admin";

export const prerender = false;

const { id } = Astro.params;
let project = null;

try {
    const projectDoc = await db.collection('projects').doc(id).get();
    if (projectDoc.exists) {
        const projectData = projectDoc.data();
        project = { 
            id: projectDoc.id, 
            projectName: projectData.projectName || 'اسم غير متوفر',
            supervisorIds: projectData.supervisorIds || [] 
        };
    } else {
       // Let the frontend handle the not found case
    }
} catch (error) {
    console.error("Error fetching project data in remains.astro:", error);
    project = null;
}

---

<Layout title={`بواقي مشروع: ${project ? project.projectName : 'غير متوفر'}`}>
    <div id="auth-loading-message" class="auth-container">
        <p>جارٍ التحقق من صلاحيات الدخول...</p>
    </div>

    <main 
        id="page-content" 
        class="remains-page" 
        style="display: none;" 
        data-project-id={project?.id}
        data-project-exists={project !== null}
        data-supervisor-ids={JSON.stringify(project?.supervisorIds || [])}
    >
         <div class="container">
            {project ? (
                <>
                    <header class="page-header">
                        <div>
                            <h1>بواقي مشروع: {project.projectName}</h1>
                            <p class="page-subtitle">صفحة مخصصة لإدارة البواقي للمشرف والأدمن.</p>
                        </div>
                        <a href={`/crs/projects/${id}`} class="back-link">&larr; العودة لتفاصيل المشروع</a>
                    </header>

                    <section class="materials-section">
                        <!-- Iron Card -->
                        <div class="material-card" id="iron-card">
                            <div class="card-header">
                                <h3>الحديد (بالسيخ)</h3>
                                <div class="iron-totals-grid">
                                    <div class="total-amount-display">
                                        <span>3 لينه:</span>
                                        <span id="iron-total-3">0</span>
                                    </div>
                                    <div class="total-amount-display">
                                        <span>4 لينه:</span>
                                        <span id="iron-total-4">0</span>
                                    </div>
                                    <div class="total-amount-display">
                                        <span>5 لينه:</span>
                                        <span id="iron-total-5">0</span>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="supervisor-only" style="display: none;">
                                    <div class="form-toggle-buttons">
                                        <button class="toggle-btn active" data-form="add-iron-form">إضافة</button>
                                        <button class="toggle-btn" data-form="dispense-iron-form">صرف</button>
                                    </div>
                                    <form id="add-iron-form" class="material-form"></form>
                                    <form id="dispense-iron-form" class="material-form" style="display: none;"></form>
                                </div>
                                <div class="admin-only" style="display: none;">
                                    <div class="log-section">
                                        <h4>سجل الحديد</h4>
                                         <div class="iron-filter-controls">
                                            <div class="filter-group">
                                                <span>النوع:</span>
                                                <div class="filter-buttons">
                                                    <button class="filter-btn active" data-filter-type="liya" data-filter-value="all">الكل</button>
                                                    <button class="filter-btn" data-filter-type="liya" data-filter-value="حديد 3 لينه">3 لينه</button>
                                                    <button class="filter-btn" data-filter-type="liya" data-filter-value="حديد 4 لينه">4 لينه</button>
                                                    <button class="filter-btn" data-filter-type="liya" data-filter-value="حديد 5 لينه">5 لينه</button>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>العملية</th><th>النوع</th><th>العدد</th><th>المشرف</th><th>السبب</th><th>الإجراءات</th></tr></thead>
                                                <tbody id="iron-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="iron-log-empty" class="log-empty">لا توجد سجلات.</p>
                                        <button id="show-all-iron" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Cement Card -->
                        <div class="material-card" id="cement-card">
                             <div class="card-header">
                                <h3>الأسمنت</h3>
                                <div class="total-amount-display simple">
                                    <span>الكمية الحالية:</span>
                                    <span id="cement-total">0</span>
                                    <span>شكارة</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="supervisor-only" style="display: none;">
                                     <div class="form-toggle-buttons">
                                        <button class="toggle-btn active" data-form="add-cement-form">إضافة</button>
                                        <button class="toggle-btn" data-form="dispense-cement-form">صرف</button>
                                    </div>
                                    <form id="add-cement-form" class="material-form"></form>
                                    <form id="dispense-cement-form" class="material-form" style="display: none;"></form>
                                </div>
                                <div class="admin-only" style="display: none;">
                                    <div class="log-section">
                                        <h4>سجل الأسمنت</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>العملية</th><th>الكمية</th><th>المشرف</th><th>السبب</th><th>الإجراءات</th></tr></thead>
                                                <tbody id="cement-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="cement-log-empty" class="log-empty">لا توجد سجلات.</p>
                                        <button id="show-all-cement" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Other Card -->
                        <div class="material-card" id="other-card">
                            <div class="card-header">
                                <h3>مواد أخرى</h3>
                               <div class="total-amount-display simple">
                                    <span>الكمية الحالية:</span>
                                    <span id="other-total">0</span>
                                     <span>وحدة</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="supervisor-only" style="display: none;">
                                    <div class="form-toggle-buttons">
                                        <button class="toggle-btn active" data-form="add-other-form">إضافة</button>
                                        <button class="toggle-btn" data-form="dispense-other-form">صرف</button>
                                    </div>
                                    <form id="add-other-form" class="material-form"></form>
                                    <form id="dispense-other-form" class="material-form" style="display: none;"></form>
                                </div>
                                <div class="admin-only" style="display: none;">
                                   <div class="log-section">
                                        <h4>سجل المواد الأخرى</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>العملية</th><th>الكمية</th><th>المشرف</th><th>السبب</th><th>الإجراءات</th></tr></thead>
                                                <tbody id="other-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="other-log-empty" class="log-empty">لا توجد سجلات.</p>
                                        <button id="show-all-other" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </section>
                </>
            ) : (
                <div class="error-card">
                    <h2>خطأ في تحميل البيانات</h2>
                    <p>تعذر العثور على المشروع المطلوب أو حدث خطأ أثناء تحميله. يرجى التأكد من صحة الرابط.</p>
                     <a href="/crs/projects" class="back-link">العودة إلى قائمة المشاريع</a>
                </div>
            )
        }
        </div>

        <!-- Edit Modal -->
        <div id="edit-modal" class="modal-overlay" style="display: none;">
            <div class="modal-content">
                <button id="close-modal" class="modal-close">&times;</button>
                <h3>تعديل السجل</h3>
                <form id="edit-form">
                    <input type="hidden" name="docId">
                    <input type="hidden" name="material">
                    
                    <div class="form-group" id="edit-iron-type-group" style="display: none;">
                        <label for="edit-iron-type">نوع الحديد</label>
                        <select id="edit-iron-type" name="ironType">
                            <option value="حديد 3 لينه">حديد 3 لينه</option>
                            <option value="حديد 4 لينه">حديد 4 لينه</option>
                            <option value="حديد 5 لينه">حديد 5 لينه</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label id="edit-quantity-label" for="edit-quantity">الكمية</label>
                        <input type="number" id="edit-quantity" name="quantity" required min="0">
                    </div>

                    <div class="form-group">
                        <label for="edit-notes">السبب</label>
                        <input type="text" id="edit-notes" name="notes" required>
                    </div>

                    <button type="submit" class="btn-submit">حفظ التعديلات</button>
                </form>
            </div>
        </div>
    </main>
</Layout>

<script>
    import { initializeAuthCheck } from '../../../../scripts/auth/remains-auth.ts';
    import { db } from '../../../../firebase/client';
    import { collection, addDoc, query, where, onSnapshot, serverTimestamp, orderBy, doc, getDoc, deleteDoc, updateDoc } from 'firebase/firestore';

    const LOG_LIMIT = 5;
    let supervisorMap = {};
    let userIsAdmin = false;
    let allLogs = { iron: [], cement: [], other: [] };
    let currentIronFilter = 'all';

    // --- DYNAMIC FORM & TABLE BUILDERS --- //

    function buildMaterialForm(isDispense, material, unit, title) {
        return `
            <h4>${title}</h4>
            <div class="form-group" style="width: 100%;">
                <label for="${isDispense ? 'dispense' : 'add'}-${material}-quantity">الكمية (${unit})</label>
                <input type="number" id="${isDispense ? 'dispense' : 'add'}-${material}-quantity" name="quantity" step="1" required placeholder="مثال: 50">
            </div>
            <div class="form-group" style="width: 100%;">
                <label for="${isDispense ? 'dispense' : 'add'}-${material}-notes">السبب</label>
                <input type="text" id="${isDispense ? 'dispense' : 'add'}-${material}-notes" name="notes" required placeholder="مثال: ${isDispense ? 'أساسات المبنى' : 'توريد للمخزون'}">
            </div>
            <button type="submit" class="btn-submit ${isDispense ? 'btn-dispense' : ''}">${isDispense ? 'صرف' : 'إضافة'}</button>
        `;
    }

    function buildIronForm(isDispense) {
        const type = isDispense ? 'dispense' : 'add';
        return `
            <h4>${isDispense ? 'صرف' : 'إضافة'} عدد أسياخ</h4>
            <div class="form-row">
                <div class="form-group">
                    <label for="${type}-iron-type">نوع الحديد</label>
                    <select id="${type}-iron-type" name="ironType" required>
                        <option value="حديد 3 لينه">حديد 3 لينه</option>
                        <option value="حديد 4 لينه">حديد 4 لينه</option>
                        <option value="حديد 5 لينه">حديد 5 لينه</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="${type}-iron-quantity">عدد الأسياخ</label>
                    <input type="number" id="${type}-iron-quantity" name="quantity" step="1" required placeholder="${isDispense ? '50' : '150'}">
                </div>
            </div>
            <div class="form-group" style="width: 100%;">
                <label for="${type}-iron-notes">السبب</label>
                <input type="text" id="${type}-iron-notes" name="notes" required placeholder="مثال: ${isDispense ? 'أعمدة الدور الأول' : 'توريد للمخزون'}">
            </div>
            <button type="submit" class="btn-submit ${isDispense ? 'btn-dispense' : ''}">${isDispense ? 'صرف' : 'إضافة'}</button>
        `;
    }

    // --- GENERIC MATERIAL SECTION SETUP --- //
    function setupMaterialSection(material, unit, projectId, user, userRole) {
        const card = document.getElementById(`${material}-card`);
        if (!card) return;

        const addForm = card.querySelector(`#add-${material}-form`);
        const dispenseForm = card.querySelector(`#dispense-${material}-form`);
        
        if (material === 'iron') {
            addForm.innerHTML = buildIronForm(false);
            dispenseForm.innerHTML = buildIronForm(true);
        } else {
            const title = material === 'cement' ? 'الأسمنت' : 'المواد الأخرى';
            addForm.innerHTML = buildMaterialForm(false, material, unit, `إضافة ${title}`);
            dispenseForm.innerHTML = buildMaterialForm(true, material, unit, `صرف ${title}`);
        }

        const toggleButtons = card.querySelectorAll('.toggle-btn');
        toggleButtons.forEach(button => {
            button.addEventListener('click', (e) => {
                card.querySelectorAll('.toggle-btn').forEach(btn => btn.classList.remove('active'));
                e.target.classList.add('active');
                const formId = e.target.dataset.form;
                card.querySelectorAll('.material-form').forEach(form => {
                    form.style.display = form.id === formId ? 'flex' : 'none';
                });
            });
        });

        const remainsQuery = query(collection(db, 'remains'), where("projectId", "==", projectId), where("material", "==", material), orderBy("createdAt", "desc"));
        onSnapshot(remainsQuery, (snapshot) => {
            allLogs[material] = [];
            let total = 0;
            let ironTotals = { '3': 0, '4': 0, '5': 0 };

            snapshot.forEach(doc => {
                const data = { id: doc.id, ...doc.data() };
                allLogs[material].push(data);
                if (material === 'iron') {
                    const type = data.ironType === 'حديد 3 لينه' ? '3' : data.ironType === 'حديد 4 لينه' ? '4' : '5';
                    if (ironTotals[type] !== undefined) ironTotals[type] += data.quantity;
                } else {
                    total += data.quantity;
                }
            });

            if (material === 'iron') {
                document.getElementById('iron-total-3').textContent = ironTotals['3'];
                document.getElementById('iron-total-4').textContent = ironTotals['4'];
                document.getElementById('iron-total-5').textContent = ironTotals['5'];
                if (userRole === 'admin') renderIronLogTable();
            } else {
                document.getElementById(`${material}-total`).textContent = total;
                if (userRole === 'admin') renderSimpleLogTable(material);
            }
        });

        if (userRole === 'admin') {
            card.addEventListener('click', handleAdminActions);
            document.getElementById(`show-all-${material}`).addEventListener('click', () => {
                if(material === 'iron') renderIronLogTable(true); else renderSimpleLogTable(material, true);
            });
             if (material === 'iron') {
                const liyaFilterButtons = card.querySelectorAll('[data-filter-type="liya"]');
                liyaFilterButtons.forEach(btn => {
                    btn.addEventListener('click', () => {
                        liyaFilterButtons.forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');
                        currentIronFilter = btn.dataset.filterValue;
                        renderIronLogTable(); 
                    });
                });
            }
        }

        if (userRole === 'admin' || userRole === 'supervisor') {
            setupFormSubmission(addForm, false, projectId, user, material);
            setupFormSubmission(dispenseForm, true, projectId, user, material);
        }
    }

    // --- LOG RENDERING --- //
    function renderSimpleLogTable(material, showAll = false) {
        const tbody = document.getElementById(`${material}-log-body`);
        const emptyMsg = document.getElementById(`${material}-log-empty`);
        const showAllBtn = document.getElementById(`show-all-${material}`);
        const entries = allLogs[material] || [];

        emptyMsg.style.display = entries.length === 0 ? 'block' : 'none';
        showAllBtn.style.display = (entries.length > LOG_LIMIT && !showAll) ? 'block' : 'none';

        const entriesToRender = showAll ? entries : entries.slice(0, LOG_LIMIT);
        tbody.innerHTML = entriesToRender.map(entry => {
            const supervisorName = entry.supervisorName || supervisorMap[entry.supervisorId] || 'مشرف غير معروف';
            const actionsHtml = userIsAdmin ? `
                <td class="log-actions">
                    <button class="btn-action btn-edit" data-id="${entry.id}" data-material="${material}">تعديل</button>
                    <button class="btn-action btn-delete" data-id="${entry.id}" data-material="${material}">حذف</button>
                </td>` : '';
            return `
                <tr>
                    <td>${entry.createdAt?.toDate().toLocaleDateString('ar-EG') || ''}</td>
                    <td class="${entry.quantity > 0 ? 'text-success' : 'text-danger'}">${entry.quantity > 0 ? 'إضافة' : 'صرف'}</td>
                    <td>${Math.abs(entry.quantity)}</td>
                    <td>${supervisorName}</td>
                    <td>${entry.notes || '-'}</td>
                    ${actionsHtml}
                </tr>
            `;
        }).join('');
    }

    function renderIronLogTable(showAll = false) {
        const tbody = document.getElementById('iron-log-body');
        const emptyMsg = document.getElementById('iron-log-empty');
        const showAllBtn = document.getElementById('show-all-iron');

        let filteredEntries = allLogs.iron;
        if (currentIronFilter !== 'all') {
            filteredEntries = filteredEntries.filter(e => e.ironType === currentIronFilter);
        }

        emptyMsg.style.display = filteredEntries.length === 0 ? 'block' : 'none';
        showAllBtn.style.display = (filteredEntries.length > LOG_LIMIT && !showAll) ? 'block' : 'none';

        const entriesToRender = showAll ? filteredEntries : filteredEntries.slice(0, LOG_LIMIT);
        tbody.innerHTML = entriesToRender.map(entry => {
            const supervisorName = entry.supervisorName || supervisorMap[entry.supervisorId] || 'مشرف غير معروف';
            const actionsHtml = userIsAdmin ? `
                <td class="log-actions">
                    <button class="btn-action btn-edit" data-id="${entry.id}" data-material="iron">تعديل</button>
                    <button class="btn-action btn-delete" data-id="${entry.id}" data-material="iron">حذف</button>
                </td>` : '';

            return `
                <tr>
                    <td>${entry.createdAt?.toDate().toLocaleDateString('ar-EG') || ''}</td>
                    <td class="${entry.quantity > 0 ? 'text-success' : 'text-danger'}">${entry.quantity > 0 ? 'إضافة' : 'صرف'}</td>
                    <td>${(entry.ironType || '').replace('حديد','').trim()}</td>
                    <td>${Math.abs(entry.quantity)}</td>
                    <td>${supervisorName}</td>
                    <td>${entry.notes || '-'}</td>
                    ${actionsHtml}
                </tr>
            `}).join('');
    }

    // --- FORM SUBMISSION --- //
    async function handleFormSubmit(e, isDispense, projectId, user, material) {
        e.preventDefault();
        const form = e.target;
        const submitBtn = form.querySelector('button[type="submit"]');
        submitBtn.disabled = true; submitBtn.textContent = 'جارٍ الحفظ...';

        try {
            const quantity = parseInt(form.quantity.value, 10);
            if (isNaN(quantity) || quantity <= 0) throw new Error('يرجى إدخال كمية صحيحة موجبة.');
            
            let data = {
                projectId, material,
                quantity: isDispense ? -quantity : quantity,
                notes: form.notes.value,
                supervisorId: user.uid,
                supervisorName: user.displayName || user.email || 'مستخدم',
                createdAt: serverTimestamp()
            };

            if (material === 'iron') {
                const ironType = form.ironType.value;
                if (!ironType) throw new Error('يرجى اختيار نوع الحديد.');
                data.ironType = ironType;
            }

            await addDoc(collection(db, 'remains'), data);
            form.reset();
            alert('تمت العملية بنجاح!');
        } catch (error) {
            console.error(`Error submitting ${material} form:`, error);
            alert(error.message || 'حدث خطأ أثناء الحفظ.');
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = isDispense ? 'صرف' : 'إضافة';
        }
    }

    function setupFormSubmission(form, isDispense, projectId, user, material) {
        if (form) {
            form.addEventListener('submit', (e) => handleFormSubmit(e, isDispense, projectId, user, material));
        }
    }

    // --- ADMIN ACTIONS (EDIT/DELETE) --- //
    function handleAdminActions(e) {
        const target = e.target.closest('button.btn-action');
        if (!target) return;
        const docId = target.dataset.id;
        const material = target.dataset.material;
        if (target.classList.contains('btn-delete')) {
            handleDelete(docId);
        } else if (target.classList.contains('btn-edit')) {
            openEditModal(docId, material);
        }
    }

    async function handleDelete(docId) {
        if (confirm('هل أنت متأكد أنك تريد حذف هذا السجل؟ لا يمكن التراجع عن هذا الإجراء.')) {
            try {
                await deleteDoc(doc(db, 'remains', docId));
                alert('تم الحذف بنجاح!');
            } catch (error) {
                console.error("Error deleting document: ", error);
                alert('حدث خطأ أثناء الحذف.');
            }
        }
    }

    function openEditModal(docId, material) {
        const modal = document.getElementById('edit-modal');
        const form = document.getElementById('edit-form');
        const ironTypeGroup = document.getElementById('edit-iron-type-group');
        const quantityLabel = document.getElementById('edit-quantity-label');
        
        form.reset();
        form.docId.value = docId;
        form.material.value = material;

        const entry = allLogs[material]?.find(log => log.id === docId);
        if (!entry) { return alert('خطأ: لم يتم العثور على السجل.'); }

        ironTypeGroup.style.display = material === 'iron' ? 'block' : 'none';
        quantityLabel.textContent = material === 'iron' ? 'العدد' : 'الكمية';
        form.quantity.value = Math.abs(entry.quantity);
        form.notes.value = entry.notes || '';
        if (material === 'iron') {
            form.ironType.value = entry.ironType;
        } 

        modal.style.display = 'flex';
    }

    document.getElementById('edit-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const docId = form.docId.value;
        const material = form.material.value;
        const submitBtn = form.querySelector('button[type="submit"]');
        submitBtn.disabled = true; submitBtn.textContent = 'جارٍ الحفظ...';
        
        try {
            const newQuantity = parseInt(form.quantity.value, 10);
            if(isNaN(newQuantity) || newQuantity < 0) throw new Error("الكمية يجب أن تكون رقمًا موجبًا.");
            
            const originalEntry = allLogs[material]?.find(log => log.id === docId);
            if (!originalEntry) throw new Error("لم يتم العثور على السجل الأصلي.");

            let updatedData = {
                notes: form.notes.value,
                quantity: originalEntry.quantity > 0 ? newQuantity : -newQuantity,
            };

            if (material === 'iron') {
                updatedData.ironType = form.ironType.value;
            }
            
            await updateDoc(doc(db, 'remains', docId), updatedData);
            alert('تم التعديل بنجاح!');
            document.getElementById('edit-modal').style.display = 'none';
        } catch(error) {
            alert(error.message || 'فشل تحديث السجل.');
        } finally {
            submitBtn.disabled = false; submitBtn.textContent = 'حفظ التعديلات';
        }
    });
    
    document.getElementById('close-modal').addEventListener('click', () => {
        document.getElementById('edit-modal').style.display = 'none';
    });

    // --- INITIALIZATION & HELPERS --- //
    async function getSupervisorNames(ids) { 
        const nameMap = {};
        if (!ids || ids.length === 0) return nameMap;
        const userPromises = ids.map(id => getDoc(doc(db, 'users', id)));
        const userDocs = await Promise.all(userPromises);
        userDocs.forEach(userDoc => {
            if (userDoc.exists()) {
                nameMap[userDoc.id] = userDoc.data().displayName || 'اسم غير معروف';
            } else {
                nameMap[userDoc.id] = 'مشرف محذوف';
            }
        });
        return nameMap;
     }

    async function initializeRemainsPage(user, userRole) {
        const pageContent = document.getElementById('page-content');
        if (!pageContent || pageContent.dataset.projectExists !== 'true') return;
        userIsAdmin = userRole === 'admin';

        const projectId = pageContent.dataset.projectId;
        const supervisorIds = JSON.parse(pageContent.dataset.supervisorIds || '[]');
        supervisorMap = await getSupervisorNames(supervisorIds);
        
        setupMaterialSection('iron', 'سيخ', projectId, user, userRole);
        setupMaterialSection('cement', 'شكارة', projectId, user, userRole);
        setupMaterialSection('other', 'وحدة', projectId, user, userRole);
    }
    initializeAuthCheck(initializeRemainsPage);

</script>

