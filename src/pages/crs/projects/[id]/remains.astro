---
import Layout from '../../../../layouts/Layout.astro';
import { db } from "../../../../firebase/admin";

export const prerender = false;

const { id } = Astro.params;
let project = null;

try {
    const projectDoc = await db.collection('projects').doc(id).get();
    if (projectDoc.exists) {
        const projectData = projectDoc.data();
        project = { 
            id: projectDoc.id, 
            projectName: projectData.projectName || 'اسم غير متوفر',
            supervisorIds: projectData.supervisorIds || [] 
        };
    } else {
       // Let the frontend handle the not found case
    }
} catch (error) {
    console.error("Error fetching project data in remains.astro:", error);
    project = null;
}

---

<Layout title={`بواقي مشروع: ${project ? project.projectName : 'غير متوفر'}`}>
    <div id="auth-loading-message" class="auth-container">
        <p>جارٍ التحقق من صلاحيات الدخول...</p>
    </div>

    <main 
        id="page-content" 
        class="remains-page" 
        style="display: none;" 
        data-project-id={project?.id}
        data-project-exists={project !== null}
        data-supervisor-ids={JSON.stringify(project?.supervisorIds || [])}
    >
         <div class="container">
            {project ? (
                <>
                    <header class="page-header">
                        <div>
                            <h1>بواقي مشروع: {project.projectName}</h1>
                            <p class="page-subtitle">صفحة مخصصة لإدارة البواقي للمشرف والأدمن.</p>
                        </div>
                        <a href={`/crs/projects/${id}`} class="back-link">&larr; العودة لتفاصيل المشروع</a>
                    </header>

                    <section class="materials-section">
                        <!-- Iron Card -->
                        <div class="material-card" id="iron-card">
                            <div class="card-header">
                                <h3>الحديد (بالسيخ والكانات)</h3>
                                <div class="material-header-content">
                                    <div class="totals-grid">
                                        <div class="total-amount-display">
                                            <span>3 لينه:</span>
                                            <span id="iron-total-3">0</span>
                                        </div>
                                        <div class="total-amount-display">
                                            <span>4 لينه:</span>
                                            <span id="iron-total-4">0</span>
                                        </div>
                                        <div class="total-amount-display">
                                            <span>5 لينه:</span>
                                            <span id="iron-total-5">0</span>
                                        </div>
                                        <div class="total-amount-display">
                                            <span>كانات 6مللي:</span>
                                            <span id="iron-total-stirrups6">0</span>
                                        </div>
                                        <div class="total-amount-display">
                                            <span>كانات 8مللي:</span>
                                            <span id="iron-total-stirrups8">0</span>
                                        </div>
                                    </div>
                                    <div class="movements-breakdown">
                                        <div class="movement-breakdown-item">
                                            <span class="movement-subtype-label">3 لينه:</span>
                                            <span class="movement-value added">مضاف: <span id="iron-added-3">0</span></span>
                                            <span class="movement-value dispensed">مصروف: <span id="iron-dispensed-3">0</span></span>
                                        </div>
                                        <div class="movement-breakdown-item">
                                            <span class="movement-subtype-label">4 لينه:</span>
                                            <span class="movement-value added">مضاف: <span id="iron-added-4">0</span></span>
                                            <span class="movement-value dispensed">مصروف: <span id="iron-dispensed-4">0</span></span>
                                        </div>
                                        <div class="movement-breakdown-item">
                                            <span class="movement-subtype-label">5 لينه:</span>
                                            <span class="movement-value added">مضاف: <span id="iron-added-5">0</span></span>
                                            <span class="movement-value dispensed">مصروف: <span id="iron-dispensed-5">0</span></span>
                                        </div>
                                        <div class="movement-breakdown-item">
                                            <span class="movement-subtype-label">كانات 6 مللي:</span>
                                            <span class="movement-value added">مضاف: <span id="iron-added-stirrups6">0</span></span>
                                            <span class="movement-value dispensed">مصروف: <span id="iron-dispensed-stirrups6">0</span></span>
                                        </div>
                                        <div class="movement-breakdown-item">
                                            <span class="movement-subtype-label">كانات 8 مللي:</span>
                                            <span class="movement-value added">مضاف: <span id="iron-added-stirrups8">0</span></span>
                                            <span class="movement-value dispensed">مصروف: <span id="iron-dispensed-stirrups8">0</span></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="supervisor-only" style="display: none;">
                                    <div class="form-toggle-buttons">
                                        <button class="toggle-btn active" data-form="add-iron-form">إضافة</button>
                                        <button class="toggle-btn" data-form="dispense-iron-form">صرف</button>
                                    </div>
                                    <form id="add-iron-form" class="material-form">
                                        <h4>إضافة حديد</h4>
                                        <div class="form-fields">
                                            <div class="form-row">
                                                <div class="form-group">
                                                    <label for="add-iron-type">نوع الحديد</label>
                                                    <select id="add-iron-type" name="subType" required>
                                                        <option value="حديد 3 لينه">حديد 3 لينه</option>
                                                        <option value="حديد 4 لينه">حديد 4 لينه</option>
                                                        <option value="حديد 5 لينه">حديد 5 لينه</option>
                                                        <option value="حديد كانات 6 مللي">كانات 6 مللي</option>
                                                        <option value="حديد كانات 8 مللي">كانات 8 مللي</option>
                                                    </select>
                                                </div>
                                                <div class="form-group">
                                                    <label for="add-iron-quantity" class="quantity-label">عدد الأسياخ</label>
                                                    <input type="number" id="add-iron-quantity" name="quantity" step="1" required placeholder="150">
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label for="add-iron-notes">السبب</label>
                                                <input type="text" id="add-iron-notes" name="notes" required>
                                            </div>
                                        </div>
                                        <div class="form-actions">
                                            <button type="submit" class="btn-submit">إضافة</button>
                                        </div>
                                    </form>
                                    <form id="dispense-iron-form" class="material-form" style="display: none;">
                                         <h4>صرف حديد</h4>
                                        <div class="form-fields">
                                            <div class="form-row">
                                                <div class="form-group">
                                                    <label for="dispense-iron-type">نوع الحديد</label>
                                                    <select id="dispense-iron-type" name="subType" required>
                                                        <option value="حديد 3 لينه">حديد 3 لينه</option>
                                                        <option value="حديد 4 لينه">حديد 4 لينه</option>
                                                        <option value="حديد 5 لينه">حديد 5 لينه</option>
                                                        <option value="حديد كانات 6 مللي">كانات 6 مللي</option>
                                                        <option value="حديد كانات 8 مللي">كانات 8 مللي</option>
                                                    </select>
                                                </div>
                                                <div class="form-group">
                                                    <label for="dispense-iron-quantity" class="quantity-label">عدد الأسياخ</label>
                                                    <input type="number" id="dispense-iron-quantity" name="quantity" step="1" required placeholder="50">
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label for="dispense-iron-notes">السبب</label>
                                                <input type="text" id="dispense-iron-notes" name="notes" required>
                                            </div>
                                        </div>
                                        <div class="form-actions">
                                            <button type="submit" class="btn-submit btn-dispense">صرف</button>
                                        </div>
                                    </form>
                                </div>
                                <div class="admin-only" style="display: none;">
                                    <div class="log-section">
                                        <h4>سجل الحديد</h4>
                                         <div class="filter-controls">
                                            <div class="filter-group">
                                                <span>النوع:</span>
                                                <div class="filter-buttons">
                                                    <button class="filter-btn active" data-material="iron" data-filter-type="subType" data-filter-value="all">الكل</button>
                                                    <button class="filter-btn" data-material="iron" data-filter-type="subType" data-filter-value="حديد 3 لينه">3 لينه</button>
                                                    <button class="filter-btn" data-material="iron" data-filter-type="subType" data-filter-value="حديد 4 لينه">4 لينه</button>
                                                    <button class="filter-btn" data-material="iron" data-filter-type="subType" data-filter-value="حديد 5 لينه">5 لينه</button>
                                                    <button class="filter-btn" data-material="iron" data-filter-type="subType" data-filter-value="حديد كانات 6 مللي">كانات 6</button>
                                                    <button class="filter-btn" data-material="iron" data-filter-type="subType" data-filter-value="حديد كانات 8 مللي">كانات 8</button>
                                                </div>
                                            </div>
                                        </div>
                                        <div id="iron-log-container" class="log-container"></div>
                                        <p id="iron-log-empty" class="log-empty">لا توجد سجلات.</p>
                                        <button id="show-all-iron" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Cement Card -->
                        <div class="material-card" id="cement-card">
                             <div class="card-header">
                                <h3>الأسمنت (بالشكارة)</h3>
                                <div class="material-header-content">
                                    <div class="total-amount-display simple">
                                        <span>الكمية الحالية:</span>
                                        <span id="cement-total">0</span>
                                        <span>شكارة</span>
                                    </div>
                                    <div class="movements-summary">
                                        <div class="movement-total added">
                                            <span>إجمالي المضاف:</span>
                                            <span id="cement-total-added">0</span>
                                        </div>
                                        <div class="movement-total dispensed">
                                            <span>إجمالي المصروف:</span>
                                            <span id="cement-total-dispensed">0</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="supervisor-only" style="display: none;">
                                     <div class="form-toggle-buttons">
                                        <button class="toggle-btn active" data-form="add-cement-form">إضافة</button>
                                        <button class="toggle-btn" data-form="dispense-cement-form">صرف</button>
                                    </div>
                                    <form id="add-cement-form" class="material-form">
                                        <h4>إضافة أسمنت</h4>
                                        <div class="form-fields">
                                            <div class="form-group">
                                                <label for="add-cement-quantity">الكمية (شكارة)</label>
                                                <input type="number" id="add-cement-quantity" name="quantity" step="1" required placeholder="50">
                                            </div>
                                            <div class="form-group">
                                                <label for="add-cement-notes">السبب</label>
                                                <input type="text" id="add-cement-notes" name="notes" required>
                                            </div>
                                        </div>
                                        <div class="form-actions">
                                            <button type="submit" class="btn-submit">إضافة</button>
                                        </div>
                                    </form>
                                    <form id="dispense-cement-form" class="material-form" style="display: none;">
                                        <h4>صرف أسمنت</h4>
                                        <div class="form-fields">
                                            <div class="form-group">
                                                <label for="dispense-cement-quantity">الكمية (شكارة)</label>
                                                <input type="number" id="dispense-cement-quantity" name="quantity" step="1" required placeholder="20">
                                            </div>
                                            <div class="form-group">
                                                <label for="dispense-cement-notes">السبب</label>
                                                <input type="text" id="dispense-cement-notes" name="notes" required>
                                            </div>
                                        </div>
                                        <div class="form-actions">
                                            <button type="submit" class="btn-submit btn-dispense">صرف</button>
                                        </div>
                                    </form>
                                </div>
                                <div class="admin-only" style="display: none;">
                                    <div class="log-section">
                                        <h4>سجل الأسمنت</h4>
                                        <div id="cement-log-container" class="log-container"></div>
                                        <p id="cement-log-empty" class="log-empty">لا توجد سجلات.</p>
                                        <button id="show-all-cement" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Other Card -->
                        <div class="material-card" id="other-card">
                            <div class="card-header">
                                <h3>مواد أخرى</h3>
                                <div class="material-header-content">
                                    <div class="totals-grid">
                                        <div class="total-amount-display">
                                            <span>مواد صبة:</span>
                                            <span id="other-total-sapa">0</span>
                                        </div>
                                        <div class="total-amount-display">
                                            <span>سوائل:</span>
                                            <span id="other-total-liquids">0</span>
                                        </div>
                                        <div class="total-amount-display">
                                            <span>أخرى:</span>
                                            <span id="other-total-misc">0</span>
                                        </div>
                                    </div>
                                    <div class="movements-summary">
                                        <div class="movement-total added">
                                            <span>إجمالي الوحدات المضافة:</span>
                                            <span id="other-total-added">0</span>
                                        </div>
                                        <div class="movement-total dispensed">
                                            <span>إجمالي الوحدات المصروفة:</span>
                                            <span id="other-total-dispensed">0</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="supervisor-only" style="display: none;">
                                    <div class="form-toggle-buttons">
                                        <button class="toggle-btn active" data-form="add-other-form">إضافة</button>
                                        <button class="toggle-btn" data-form="dispense-other-form">صرف</button>
                                    </div>
                                     <form id="add-other-form" class="material-form">
                                        <h4>إضافة مواد أخرى</h4>
                                        <div class="form-fields">
                                            <div class="form-row">
                                                <div class="form-group">
                                                    <label for="add-other-type">نوع المادة</label>
                                                    <select name="subType" class="subType-select" required>
                                                        <option value="مواد صبة">مواد صبة</option>
                                                        <option value="سوائل">سوائل</option>
                                                        <option value="أخرى">أخرى</option>
                                                    </select>
                                                </div>
                                                <div class="form-group conditional-field" style="display: none;">
                                                    <label for="add-other-custom-subtype">تحديد النوع</label>
                                                    <input type="text" name="customSubType" placeholder="مثال: أدوات سباكة">
                                                </div>
                                            </div>
                                            <div class="form-row">
                                                <div class="form-group">
                                                    <label for="add-other-quantity">الكمية</label>
                                                    <input type="number" name="quantity" step="1" required placeholder="10">
                                                </div>
                                                 <div class="form-group">
                                                    <label for="add-other-unit">وحدة القياس</label>
                                                    <select name="unit" class="unit-select" required>
                                                        <option value="قطعة">قطعة</option>
                                                        <option value="لتر">لتر</option>
                                                        <option value="أخرى">أخرى</option>
                                                    </select>
                                                </div>
                                                <div class="form-group conditional-field" style="display: none;">
                                                    <label for="add-other-custom-unit">تحديد الوحدة</label>
                                                    <input type="text" name="customUnit" placeholder="مثال: كرتونة">
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label for="add-other-notes">السبب</label>
                                                <input type="text" name="notes" required>
                                            </div>
                                        </div>
                                        <div class="form-actions">
                                            <button type="submit" class="btn-submit">إضافة</button>
                                        </div>
                                    </form>
                                    <form id="dispense-other-form" class="material-form" style="display: none;">
                                        <h4>صرف مواد أخرى</h4>
                                         <div class="form-fields">
                                            <div class="form-row">
                                                <div class="form-group">
                                                    <label for="dispense-other-type">نوع المادة</label>
                                                    <select name="subType" class="subType-select" required>
                                                        <option value="مواد صبة">مواد صبة</option>
                                                        <option value="سوائل">سوائل</option>
                                                        <option value="أخرى">أخرى</option>
                                                    </select>
                                                </div>
                                                <div class="form-group conditional-field" style="display: none;">
                                                    <label for="dispense-other-custom-subtype">تحديد النوع</label>
                                                    <input type="text" name="customSubType" placeholder="مثال: أدوات سباكة">
                                                </div>
                                            </div>
                                            <div class="form-row">
                                                <div class="form-group">
                                                    <label for="dispense-other-quantity">الكمية</label>
                                                    <input type="number" name="quantity" step="1" required placeholder="5">
                                                </div>
                                                 <div class="form-group">
                                                    <label for="dispense-other-unit">وحدة القياس</label>
                                                    <select name="unit" class="unit-select" required>
                                                        <option value="قطعة">قطعة</option>
                                                        <option value="لتر">لتر</option>
                                                        <option value="أخرى">أخرى</option>
                                                    </select>
                                                </div>
                                                <div class="form-group conditional-field" style="display: none;">
                                                    <label for="dispense-other-custom-unit">تحديد الوحدة</label>
                                                    <input type="text" name="customUnit" placeholder="مثال: كرتونة">
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label for="dispense-other-notes">السبب</label>
                                                <input type="text" name="notes" required>
                                            </div>
                                        </div>
                                        <div class="form-actions">
                                            <button type="submit" class="btn-submit btn-dispense">صرف</button>
                                        </div>
                                    </form>
                                </div>
                                <div class="admin-only" style="display: none;">
                                   <div class="log-section">
                                        <h4>سجل المواد الأخرى</h4>
                                         <div class="filter-controls">
                                            <div class="filter-group">
                                                <span>النوع:</span>
                                                <div class="filter-buttons">
                                                    <button class="filter-btn active" data-material="other" data-filter-type="subType" data-filter-value="all">الكل</button>
                                                    <button class="filter-btn" data-material="other" data-filter-type="subType" data-filter-value="مواد صبة">مواد صبة</button>
                                                    <button class="filter-btn" data-material="other" data-filter-type="subType" data-filter-value="سوائل">سوائل</button>
                                                    <button class="filter-btn" data-material="other" data-filter-type="subType" data-filter-value="أخرى">أخرى</button>
                                                </div>
                                            </div>
                                        </div>
                                        <div id="other-log-container" class="log-container"></div>
                                        <p id="other-log-empty" class="log-empty">لا توجد سجلات.</p>
                                        <button id="show-all-other" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </section>
                </>
            ) : (
                <div class="error-card">
                    <h2>خطأ في تحميل البيانات</h2>
                    <p>تعذر العثور على المشروع المطلوب أو حدث خطأ أثناء تحميله. يرجى التأكد من صحة الرابط.</p>
                     <a href="/crs/projects" class="back-link">العودة إلى قائمة المشاريع</a>
                </div>
            )
        }
        </div>

        <!-- Edit Modal -->
        <div id="edit-modal" class="modal-overlay" style="display: none;">
            <div class="modal-content">
                <button class="modal-close">&times;</button>
                <h3>تعديل السجل</h3>
                <form id="edit-form">
                    <input type="hidden" name="docId">
                    <input type="hidden" name="material">
                    
                    <div class="form-group" id="edit-subtype-group" style="display: none;">
                        <label for="edit-subtype">النوع</label>
                        <select id="edit-subtype" name="subType"></select>
                        <input type="text" id="edit-custom-subtype" name="customSubType" class="conditional-field" style="display: none; margin-top: 10px;" placeholder="تحديد النوع">
                    </div>

                     <div class="form-group" id="edit-unit-group" style="display: none;">
                        <label for="edit-unit">وحدة القياس</label>
                        <select id="edit-unit" name="unit">
                            <option value="قطعة">قطعة</option>
                            <option value="لتر">لتر</option>
                            <option value="أخرى">أخرى</option>
                        </select>
                        <input type="text" id="edit-custom-unit" name="customUnit" class="conditional-field" style="display: none; margin-top: 10px;" placeholder="تحديد الوحدة">
                    </div>

                    <div class="form-group">
                        <label id="edit-quantity-label" for="edit-quantity">الكمية</label>
                        <input type="number" id="edit-quantity" name="quantity" required min="0">
                    </div>

                    <div class="form-group">
                        <label for="edit-notes">السبب</label>
                        <input type="text" id="edit-notes" name="notes" required>
                    </div>

                    <button type="submit" class="btn-submit">حفظ التعديلات</button>
                </form>
            </div>
        </div>

        <!-- Delete Confirmation Modal -->
        <div id="delete-confirm-modal" class="modal-overlay" style="display: none;">
            <div class="modal-content">
                 <button class="modal-close">&times;</button>
                <h3>تأكيد الحذف</h3>
                <p>هل أنت متأكد أنك تريد حذف هذا السجل؟ لا يمكن التراجع عن هذا الإجراء.</p>
                <div class="modal-actions">
                    <button id="cancel-delete-btn" class="btn-cancel">إلغاء</button>
                    <button id="confirm-delete-btn" class="btn-submit btn-danger">تأكيد الحذف</button>
                </div>
            </div>
        </div>

        <!-- TEMPLATES FOR LOG CARDS -->
        <template id="detailed-log-card-template">
             <div class="log-card">
                <div class="log-card-header">
                    <span class="log-action-type"></span>
                    <span class="log-date"></span>
                </div>
                <div class="log-card-body">
                    <dl class="log-details-list">
                        <div class="log-detail-item">
                            <dt>النوع</dt>
                            <dd data-key="subType"></dd>
                        </div>
                        <div class="log-detail-item">
                            <dt data-key="quantity-label">الكمية</dt>
                            <dd data-key="quantity"></dd>
                        </div>
                        <div class="log-detail-item">
                            <dt>المشرف</dt>
                            <dd data-key="supervisor"></dd>
                        </div>
                        <div class="log-detail-item-full">
                            <dt>السبب</dt>
                            <dd data-key="notes"></dd>
                        </div>
                    </dl>
                </div>
                <div class="log-card-actions">
                    <button class="btn-action btn-edit">تعديل</button>
                    <button class="btn-action btn-delete">حذف</button>
                </div>
            </div>
        </template>

        <template id="simple-log-card-template">
            <div class="log-card">
                <div class="log-card-header">
                    <span class="log-action-type"></span>
                    <span class="log-date"></span>
                </div>
                <div class="log-card-body">
                    <dl class="log-details-list">
                        <div class="log-detail-item">
                            <dt>الكمية</dt>
                            <dd data-key="quantity"></dd>
                        </div>
                        <div class="log-detail-item">
                            <dt>المشرف</dt>
                            <dd data-key="supervisor"></dd>
                        </div>
                        <div class="log-detail-item-full">
                            <dt>السبب</dt>
                            <dd data-key="notes"></dd>
                        </div>
                    </dl>
                </div>
                <div class="log-card-actions">
                    <button class="btn-action btn-edit">تعديل</button>
                    <button class="btn-action btn-delete">حذف</button>
                </div>
            </div>
        </template>

    </main>
</Layout>

<script>
    import { initializeAuthCheck } from '../../../../scripts/auth/remains-auth.ts';
    import { db } from '../../../../firebase/client';
    import { collection, addDoc, query, where, onSnapshot, serverTimestamp, orderBy, doc, getDoc, deleteDoc, updateDoc } from 'firebase/firestore';

    const LOG_LIMIT = 3;
    let supervisorMap = {};
    let userIsAdmin = false;
    let allLogs = { iron: [], cement: [], other: [] };
    let currentFilters = { iron: 'all', other: 'all' };
    let docIdToDelete = null;

    // This object will hold the live totals for all materials.
    let liveTotals = {
        iron: { '3': 0, '4': 0, '5': 0, stirrups6: 0, stirrups8: 0 },
        cement: 0,
        other: { sapa: 0, liquids: 0, misc: 0 }
    };

    const standardSubTypes = {
        iron: ["حديد 3 لينه", "حديد 4 لينه", "حديد 5 لينه", "حديد كانات 6 مللي", "حديد كانات 8 مللي"],
        other: ["مواد صبة", "سوائل"]
    };
    const standardUnits = { 
        other: ["قطعة", "لتر"] 
    };

    // --- DYNAMIC LABEL CHANGE HANDLER ---
    function handleIronTypeChange(event) {
        const selectedValue = event.target.value;
        const form = event.target.closest('form');
        const quantityLabel = form.querySelector('.quantity-label');
        if (quantityLabel) {
            if (selectedValue.includes('كانات')) {
                quantityLabel.textContent = 'عدد الكانات';
            } else {
                quantityLabel.textContent = 'عدد الأسياخ';
            }
        }
    }

    // --- GENERIC MATERIAL SECTION SETUP --- //
    function setupMaterialSection(material, projectId, user, userRole) {
        const card = document.getElementById(`${material}-card`);
        if (!card) return;

        const toggleButtons = card.querySelectorAll('.toggle-btn');
        toggleButtons.forEach(button => {
            button.addEventListener('click', (e) => {
                card.querySelectorAll('.toggle-btn').forEach(btn => btn.classList.remove('active'));
                e.target.classList.add('active');
                const formId = e.target.dataset.form;
                card.querySelectorAll('.material-form').forEach(form => {
                    form.style.display = form.id === formId ? 'flex' : 'none';
                });
            });
        });

        if (material === 'iron') {
            card.querySelectorAll('select[name="subType"]').forEach(select => {
                select.addEventListener('change', handleIronTypeChange);
                 // Trigger it once on load to set the initial correct label
                handleIronTypeChange({ target: select });
            });
        }

        const remainsQuery = query(collection(db, 'remains'), where("projectId", "==", projectId), where("material", "==", material), orderBy("createdAt", "desc"));
        onSnapshot(remainsQuery, (snapshot) => {
            allLogs[material] = [];
            // Reset totals before recalculating
            liveTotals.iron = { '3': 0, '4': 0, '5': 0, stirrups6: 0, stirrups8: 0 };
            liveTotals.cement = 0;
            liveTotals.other = { sapa: 0, liquids: 0, misc: 0 };

            let movementTotals = { '3': {added: 0, dispensed: 0}, '4': {added: 0, dispensed: 0}, '5': {added: 0, dispensed: 0}, stirrups6: {added: 0, dispensed: 0}, stirrups8: {added: 0, dispensed: 0} };
            let simpleTotalAdded = 0;
            let simpleTotalDispensed = 0;

            snapshot.forEach(doc => {
                const data = { id: doc.id, ...doc.data() };
                allLogs[material].push(data);
                const quantity = data.quantity;
                const absQuantity = Math.abs(quantity);

                if (material === 'iron') {
                    let subTypeKey = null;
                    if (data.subType === 'حديد 3 لينه') subTypeKey = '3';
                    else if (data.subType === 'حديد 4 لينه') subTypeKey = '4';
                    else if (data.subType === 'حديد 5 لينه') subTypeKey = '5';
                    else if (data.subType === 'حديد كانات 6 مللي') subTypeKey = 'stirrups6';
                    else if (data.subType === 'حديد كانات 8 مللي') subTypeKey = 'stirrups8';

                    if(subTypeKey) {
                        liveTotals.iron[subTypeKey] += quantity;
                        if (quantity > 0) {
                            movementTotals[subTypeKey].added += absQuantity;
                        } else {
                            movementTotals[subTypeKey].dispensed += absQuantity;
                        }
                    }
                } else if (material === 'other') {
                    let typeKey = 'misc';
                    if (data.subType === 'مواد صبة') typeKey = 'sapa';
                    else if (data.subType === 'سوائل') typeKey = 'liquids';
                    liveTotals.other[typeKey] += quantity;
                } else {
                    liveTotals.cement += quantity;
                }

                if(data.quantity > 0) simpleTotalAdded += absQuantity; else simpleTotalDispensed += absQuantity;
            });

            // Update UI
            if (material === 'iron') {
                for (const key in liveTotals.iron) {
                    const totalEl = document.getElementById(`iron-total-${key}`);
                    if(totalEl) totalEl.textContent = liveTotals.iron[key];
                }
                for (const key in movementTotals) {
                    const addedEl = document.getElementById(`iron-added-${key}`);
                    const dispensedEl = document.getElementById(`iron-dispensed-${key}`);
                    if(addedEl) addedEl.textContent = movementTotals[key].added;
                    if(dispensedEl) dispensedEl.textContent = movementTotals[key].dispensed;
                }

            } else if (material === 'other') {
                 for (const key in liveTotals.other) {
                    const totalEl = document.getElementById(`other-total-${key}`);
                    if(totalEl) totalEl.textContent = liveTotals.other[key];
                }
                 document.getElementById(`${material}-total-added`).textContent = simpleTotalAdded;
                 document.getElementById(`${material}-total-dispensed`).textContent = simpleTotalDispensed;
            } else { // For simple materials like cement
                document.getElementById(`${material}-total`).textContent = liveTotals.cement;
                document.getElementById(`${material}-total-added`).textContent = simpleTotalAdded;
                document.getElementById(`${material}-total-dispensed`).textContent = simpleTotalDispensed;
            }

            if (userRole === 'admin') {
                if(material === 'cement') renderSimpleLog(material);
                else renderDetailedLog(material); 
            }
        });

        if (userRole === 'admin') {
            card.addEventListener('click', handleAdminActions);
            const showAllBtn = document.getElementById(`show-all-${material}`);
            if(showAllBtn) showAllBtn.addEventListener('click', () => {
                 if(material === 'cement') renderSimpleLog(material, true);
                else renderDetailedLog(material, true);
            });

            const filterButtons = card.querySelectorAll(`.filter-btn[data-material="${material}"]`);
            filterButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    filterButtons.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    currentFilters[material] = btn.dataset.filterValue;
                    renderDetailedLog(material);
                });
            });
        }

        if (userRole === 'admin' || userRole === 'supervisor') {
            const addForm = card.querySelector(`#add-${material}-form`);
            const dispenseForm = card.querySelector(`#dispense-${material}-form`);
            if(addForm) setupForm(addForm, false, projectId, user, material);
            if(dispenseForm) setupForm(dispenseForm, true, projectId, user, material);
        }
    }

    function setupConditionalFields(form) {
        const subTypeSelect = form.querySelector('.subType-select');
        const customSubTypeInput = form.querySelector('input[name="customSubType"]');
        const unitSelect = form.querySelector('.unit-select');
        const customUnitInput = form.querySelector('input[name="customUnit"]');

        if (subTypeSelect && customSubTypeInput) {
            subTypeSelect.addEventListener('change', (e) => {
                customSubTypeInput.parentElement.style.display = e.target.value === 'أخرى' ? 'block' : 'none';
            });
        }
        if (unitSelect && customUnitInput) {
             unitSelect.addEventListener('change', (e) => {
                customUnitInput.parentElement.style.display = e.target.value === 'أخرى' ? 'block' : 'none';
            });
        }
    }

    function setupForm(form, isDispense, projectId, user, material) {
        if (form) {
            form.addEventListener('submit', (e) => handleFormSubmit(e, isDispense, projectId, user, material));
            if (material === 'other') {
                setupConditionalFields(form);
            }
        }
    }

    // --- LOG RENDERING FUNCTIONS --- //
    function renderDetailedLog(material, showAll = false) {
        const container = document.getElementById(`${material}-log-container`);
        const emptyMsg = document.getElementById(`${material}-log-empty`);
        const showAllBtn = document.getElementById(`show-all-${material}`);
        const template = document.getElementById('detailed-log-card-template');

        if (!container || !emptyMsg || !showAllBtn || !template) return;

        let filteredEntries = allLogs[material];
        const filterValue = currentFilters[material];
        if (filterValue !== 'all') {
            filteredEntries = filteredEntries.filter(e => {
                 if (filterValue === 'أخرى') {
                    // Show entries whose subType is NOT one of the standard ones.
                    return !standardSubTypes[material].includes(e.subType);
                 } else {
                    return e.subType === filterValue;
                 }
            });
        }
        
        emptyMsg.style.display = filteredEntries.length === 0 ? 'block' : 'none';
        showAllBtn.style.display = (filteredEntries.length > LOG_LIMIT && !showAll) ? 'block' : 'none';
        const entriesToRender = showAll ? filteredEntries : filteredEntries.slice(0, LOG_LIMIT);
        container.innerHTML = ''; 

        entriesToRender.forEach(entry => {
            const cardClone = template.content.cloneNode(true);
            const isAddition = entry.quantity > 0;
            const supervisorName = entry.supervisorName || supervisorMap[entry.supervisorId] || 'مشرف غير معروف';

            cardClone.querySelector('.log-card').classList.add(isAddition ? 'log-card-add' : 'log-card-dispense');
            cardClone.querySelector('.log-action-type').textContent = isAddition ? 'إضافة' : 'صرف';
            cardClone.querySelector('.log-date').textContent = entry.createdAt?.toDate().toLocaleString('ar-EG', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', hour12: true }) || '';
            
            const subTypeDisplay = (material === 'iron') ? (entry.subType || '').replace('حديد', '').trim() : (entry.subType || 'غير محدد');
            cardClone.querySelector('[data-key="subType"]').textContent = subTypeDisplay;

            const quantityLabelDt = cardClone.querySelector('[data-key="quantity-label"]');
            const isStirrup = entry.subType && entry.subType.includes('كانات');
            if (quantityLabelDt) quantityLabelDt.textContent = isStirrup ? 'عدد الكانات' : 'عدد الأسياخ';
            
            const unit = isStirrup ? 'كانة' : 'سيخ';
            cardClone.querySelector('[data-key="quantity"]').textContent = `${Math.abs(entry.quantity)} ${unit}`;

            cardClone.querySelector('[data-key="supervisor"]').textContent = supervisorName;
            cardClone.querySelector('[data-key="notes"]').textContent = entry.notes || '-';
            
            if (userIsAdmin) {
                cardClone.querySelector('.btn-edit').dataset.id = entry.id;
                cardClone.querySelector('.btn-edit').dataset.material = material;
                cardClone.querySelector('.btn-delete').dataset.id = entry.id;
                cardClone.querySelector('.btn-delete').dataset.material = material;
            } else {
                cardClone.querySelector('.log-card-actions')?.remove();
            }

            container.appendChild(cardClone);
        });
    }

    function renderSimpleLog(material, showAll = false) {
        const container = document.getElementById(`${material}-log-container`);
        const emptyMsg = document.getElementById(`${material}-log-empty`);
        const showAllBtn = document.getElementById(`show-all-${material}`);
        const template = document.getElementById('simple-log-card-template');
        if (!container || !emptyMsg || !showAllBtn || !template) return;

        const entries = allLogs[material] || [];
        emptyMsg.style.display = entries.length === 0 ? 'block' : 'none';
        showAllBtn.style.display = (entries.length > LOG_LIMIT && !showAll) ? 'block' : 'none';

        const entriesToRender = showAll ? entries : entries.slice(0, LOG_LIMIT);
        container.innerHTML = ''; 

        entriesToRender.forEach(entry => {
            const cardClone = template.content.cloneNode(true);
            const isAddition = entry.quantity > 0;
            const supervisorName = entry.supervisorName || supervisorMap[entry.supervisorId] || 'مشرف غير معروف';

            cardClone.querySelector('.log-card').classList.add(isAddition ? 'log-card-add' : 'log-card-dispense');
            cardClone.querySelector('.log-action-type').textContent = isAddition ? 'إضافة' : 'صرف';
            cardClone.querySelector('.log-date').textContent = entry.createdAt?.toDate().toLocaleString('ar-EG', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', hour12: true }) || '';
            cardClone.querySelector('[data-key="quantity"]').textContent = `${Math.abs(entry.quantity)} شكارة`;
            cardClone.querySelector('[data-key="supervisor"]').textContent = supervisorName;
            cardClone.querySelector('[data-key="notes"]').textContent = entry.notes || '-';

            if (userIsAdmin) {
                cardClone.querySelector('.btn-edit').dataset.id = entry.id;
                cardClone.querySelector('.btn-edit').dataset.material = material;
                cardClone.querySelector('.btn-delete').dataset.id = entry.id;
                cardClone.querySelector('.btn-delete').dataset.material = material;
            } else {
                cardClone.querySelector('.log-card-actions')?.remove();
            }
            container.appendChild(cardClone);
        });
    }

    // --- FORM SUBMISSION --- //
    async function handleFormSubmit(e, isDispense, projectId, user, material) {
        e.preventDefault();
        const form = e.target;
        const submitBtn = form.querySelector('button[type="submit"]');
        
        const quantity = parseInt(form.quantity.value, 10);
        if (isNaN(quantity) || quantity <= 0) {
            alert('يرجى إدخال كمية صحيحة موجبة.');
            return;
        }

        if (isDispense) {
            let currentStock = 0;
            let subTypeKey;

            if (material === 'iron') {
                const subType = form.subType.value;
                if (subType === 'حديد 3 لينه') subTypeKey = '3';
                else if (subType === 'حديد 4 لينه') subTypeKey = '4';
                else if (subType === 'حديد 5 لينه') subTypeKey = '5';
                else if (subType === 'حديد كانات 6 مللي') subTypeKey = 'stirrups6';
                else if (subType === 'حديد كانات 8 مللي') subTypeKey = 'stirrups8';
                currentStock = liveTotals.iron[subTypeKey] || 0;
            } else if (material === 'cement') {
                currentStock = liveTotals.cement || 0;
            } else if (material === 'other') {
                const subType = form.subType.value;
                if(subType === 'مواد صبة') subTypeKey = 'sapa';
                else if (subType === 'سوائل') subTypeKey = 'liquids';
                else subTypeKey = 'misc';
                currentStock = liveTotals.other[subTypeKey] || 0;
            }

            if (quantity > currentStock) {
                alert(`لا يمكن صرف كمية أكبر من الرصيد الحالي (${currentStock}).`);
                return;
            }
        }

        submitBtn.disabled = true; 
        submitBtn.textContent = 'جارٍ الحفظ...';

        try {
            let supervisorName = user.email || 'مستخدم غير معروف'; 
            try {
                const userDocRef = doc(db, 'users', user.uid);
                const userDocSnap = await getDoc(userDocRef);
                if (userDocSnap.exists()) {
                    supervisorName = userDocSnap.data().displayName || supervisorName;
                }
            } catch (userDocError) {
                console.error("Error fetching user document:", userDocError);
            }

            let data = {
                projectId, material,
                quantity: isDispense ? -quantity : quantity,
                notes: form.notes.value,
                supervisorId: user.uid,
                supervisorName: supervisorName, 
                createdAt: serverTimestamp()
            };
            
            if (standardSubTypes[material]) {
                let subType = form.subType.value;
                if (subType === 'أخرى') {
                    subType = form.customSubType.value.trim();
                    if (!subType) throw new Error('يرجى تحديد النوع المخصص.');
                }
                data.subType = subType;
            }

            if (material === 'other') {
                let unit = form.unit.value;
                if (unit === 'أخرى') {
                    unit = form.customUnit.value.trim();
                     if (!unit) throw new Error('يرجى تحديد الوحدة المخصصة.');
                }
                data.unit = unit;
            }

            await addDoc(collection(db, 'remains'), data);
            form.reset();
            form.querySelectorAll('.conditional-field').forEach(f => f.style.display = 'none');
            alert('تمت العملية بنجاح!');
        } catch (error) {
            console.error(`Error submitting ${material} form:`, error);
            alert(error.message || 'حدث خطأ أثناء الحفظ.');
        } finally {
            submitBtn.disabled = false;
            const buttonText = form.id.includes('dispense') ? 'صرف' : 'إضافة';
            submitBtn.textContent = buttonText;
             if (material === 'iron') {
                handleIronTypeChange({ target: form.querySelector('select[name="subType"]') });
            }
        }
    }

    // --- ADMIN ACTIONS (EDIT/DELETE) --- //
    function handleAdminActions(e) {
        const target = e.target.closest('button.btn-action');
        if (!target) return;
        const docId = target.dataset.id;
        const material = target.dataset.material;
        if (target.classList.contains('btn-delete')) {
            openDeleteConfirmation(docId);
        } else if (target.classList.contains('btn-edit')) {
            openEditModal(docId, material);
        }
    }

    function openDeleteConfirmation(docId) {
        docIdToDelete = docId;
        document.getElementById('delete-confirm-modal').style.display = 'flex';
    }

    async function handleDelete() {
        if (!docIdToDelete) return;
        try {
            await deleteDoc(doc(db, 'remains', docIdToDelete));
            alert('تم الحذف بنجاح!');
        } catch (error) {
            console.error("Error deleting document: ", error);
            alert('حدث خطأ أثناء الحذف.');
        } finally {
            closeDeleteConfirmation();
        }
    }

     function closeDeleteConfirmation() {
        docIdToDelete = null;
        document.getElementById('delete-confirm-modal').style.display = 'none';
    }

    function openEditModal(docId, material) {
        const modal = document.getElementById('edit-modal');
        const form = document.getElementById('edit-form');
        const subTypeGroup = document.getElementById('edit-subtype-group');
        const subTypeSelect = document.getElementById('edit-subtype');
        const customSubTypeInput = document.getElementById('edit-custom-subtype');
        const unitGroup = document.getElementById('edit-unit-group');
        const unitSelect = document.getElementById('edit-unit');
        const customUnitInput = document.getElementById('edit-custom-unit');
        
        form.reset();
        [customSubTypeInput, customUnitInput].forEach(el => el.style.display = 'none');
        form.docId.value = docId;
        form.material.value = material;

        const entry = allLogs[material]?.find(log => log.id === docId);
        if (!entry) { return alert('خطأ: لم يتم العثور على السجل.'); }

        // Handle SubType
        if (standardSubTypes[material]) {
            subTypeSelect.innerHTML = '';
            const options = [...standardSubTypes[material], 'أخرى'];
            options.forEach(type => {
                const option = document.createElement('option');
                option.value = type;
                option.textContent = (material === 'iron') ? type.replace('حديد','').trim() : type;
                subTypeSelect.appendChild(option);
            });

            if (standardSubTypes[material].includes(entry.subType)) {
                subTypeSelect.value = entry.subType;
            } else {
                subTypeSelect.value = 'أخرى';
                customSubTypeInput.value = entry.subType;
                customSubTypeInput.style.display = 'block';
            }
            subTypeGroup.style.display = 'block';
        } else {
             subTypeGroup.style.display = 'none';
        }

        // Handle Unit (for 'other' material)
        if (material === 'other') {
             if (standardUnits.other.includes(entry.unit)) {
                unitSelect.value = entry.unit;
            } else {
                unitSelect.value = 'أخرى';
                customUnitInput.value = entry.unit;
                customUnitInput.style.display = 'block';
            }
            unitGroup.style.display = 'block';
        } else {
            unitGroup.style.display = 'none';
        }
        
        const quantityLabel = document.getElementById('edit-quantity-label');
        if (material === 'iron') {
            quantityLabel.textContent = entry.subType && entry.subType.includes('كانات') ? 'عدد الكانات' : 'عدد الأسياخ';
        } else {
            quantityLabel.textContent = 'الكمية';
        }

        form.quantity.value = Math.abs(entry.quantity);
        form.notes.value = entry.notes || '';
        
        modal.style.display = 'flex';
    }

    async function handleEditSubmit(e) {
        e.preventDefault();
        const form = e.target;
        const { docId, material, quantity, notes, subType, customSubType, unit, customUnit } = form.elements;
        const submitBtn = form.querySelector('button[type="submit"]');
        submitBtn.disabled = true; submitBtn.textContent = 'جارٍ الحفظ...';
        
        try {
            const newQuantity = parseInt(quantity.value, 10);
            if(isNaN(newQuantity) || newQuantity < 0) throw new Error("الكمية يجب أن تكون رقمًا موجبًا.");
            
            const originalEntry = allLogs[material.value]?.find(log => log.id === docId.value);
            if (!originalEntry) throw new Error("لم يتم العثور على السجل الأصلي.");

            let updatedData = {
                notes: notes.value,
                quantity: originalEntry.quantity > 0 ? newQuantity : -newQuantity,
            };

            if (standardSubTypes[material.value]) {
                let finalSubType = subType.value;
                if (finalSubType === 'أخرى') {
                    finalSubType = customSubType.value.trim();
                    if (!finalSubType) throw new Error('يرجى تحديد النوع المخصص.');
                }
                updatedData.subType = finalSubType;
            }

            if (material.value === 'other') {
                let finalUnit = unit.value;
                if (finalUnit === 'أخرى') {
                    finalUnit = customUnit.value.trim();
                    if (!finalUnit) throw new Error('يرجى تحديد الوحدة المخصصة.');
                }
                updatedData.unit = finalUnit;
            }
            
            await updateDoc(doc(db, 'remains', docId.value), updatedData);
            alert('تم التعديل بنجاح!');
            document.getElementById('edit-modal').style.display = 'none';
        } catch(error) {
            alert(error.message || 'فشل تحديث السجل.');
        } finally {
            submitBtn.disabled = false; submitBtn.textContent = 'حفظ التعديلات';
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        const editModal = document.getElementById('edit-modal');
        editModal.querySelector('.modal-close').addEventListener('click', () => editModal.style.display = 'none');
        document.getElementById('edit-form').addEventListener('submit', handleEditSubmit);
        setupConditionalFields(document.getElementById('edit-form'));

        const deleteModal = document.getElementById('delete-confirm-modal');
        deleteModal.querySelector('.modal-close').addEventListener('click', closeDeleteConfirmation);
        document.getElementById('cancel-delete-btn').addEventListener('click', closeDeleteConfirmation);
        document.getElementById('confirm-delete-btn').addEventListener('click', handleDelete);
    });


    // --- INITIALIZATION & HELPERS --- //
    async function getSupervisorNames(ids) { 
        const nameMap = {};
        if (!ids || ids.length === 0) return nameMap;
        const userPromises = ids.map(id => getDoc(doc(db, 'users', id)));
        const userDocs = await Promise.all(userPromises);
        userDocs.forEach(userDoc => {
            if (userDoc.exists()) {
                nameMap[userDoc.id] = userDoc.data().displayName || 'اسم غير معروف';
            } else {
                nameMap[userDoc.id] = 'مشرف محذوف';
            }
        });
        return nameMap;
     }

    async function initializeRemainsPage(user, userRole) {
        const pageContent = document.getElementById('page-content');
        if (!pageContent || pageContent.dataset.projectExists !== 'true') return;
        userIsAdmin = userRole === 'admin';

        const projectId = pageContent.dataset.projectId;
        const supervisorIds = JSON.parse(pageContent.dataset.supervisorIds || '[]');
        supervisorMap = await getSupervisorNames(supervisorIds);
        
        setupMaterialSection('iron', projectId, user, userRole);
        setupMaterialSection('cement', projectId, user, userRole);
        setupMaterialSection('other', projectId, user, userRole);

        document.querySelectorAll('.material-form').forEach(form => {
             if (form.id.startsWith('add-')) {
                 form.style.display = 'flex'; 
             } else {
                 form.style.display = 'none';
             }
        });
    }
    initializeAuthCheck(initializeRemainsPage);

</script>

