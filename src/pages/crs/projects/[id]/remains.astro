---
import Layout from '../../../../layouts/Layout.astro';
import { db } from "../../../../firebase/admin";

export const prerender = false;

const { id } = Astro.params;
let project = null;

try {
    const projectDoc = await db.collection('projects').doc(id).get();
    if (projectDoc.exists) {
        const projectData = projectDoc.data();
        project = { 
            id: projectDoc.id, 
            projectName: projectData.projectName || 'اسم غير متوفر',
            supervisorIds: projectData.supervisorIds || [] 
        };
    } else {
       // Let the frontend handle the not found case
    }
} catch (error) {
    console.error("Error fetching project data in remains.astro:", error);
    project = null;
}

---

<Layout title={`بواقي مشروع: ${project ? project.projectName : 'غير متوفر'}`}>
    <div id="auth-loading-message" class="auth-container">
        <p>جارٍ التحقق من صلاحيات الدخول...</p>
    </div>

    <main 
        id="page-content" 
        class="remains-page" 
        style="display: none;" 
        data-project-id={project?.id}
        data-project-exists={project !== null}
        data-supervisor-ids={JSON.stringify(project?.supervisorIds || [])}
    >
         <div class="container">
            {project ? (
                <>
                    <header class="page-header">
                        <div>
                            <h1>بواقي مشروع: {project.projectName}</h1>
                            <p class="page-subtitle">صفحة مخصصة لإدارة البواقي للمشرف والأدمن.</p>
                        </div>
                        <a href={`/crs/projects/${id}`} class="back-link">&larr; العودة لتفاصيل المشروع</a>
                    </header>

                    <section class="materials-section">
                        <!-- Iron Card -->
                        <div class="material-card" id="iron-card">
                            <div class="card-header">
                                <h3>الحديد (بالسيخ)</h3>
                                <div class="total-amount-display">
                                    <span>الكمية الحالية:</span>
                                    <span id="iron-total">جاري التحميل...</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="supervisor-only" style="display: none;">
                                    <div class="form-toggle-buttons">
                                        <button class="toggle-btn active" data-form="add-iron-form">إضافة كمية</button>
                                        <button class="toggle-btn" data-form="dispense-iron-form">صرف كمية</button>
                                    </div>
                                    <form id="add-iron-form" class="material-form">
                                        <h4>إضافة عدد أسياخ</h4>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="add-iron-quantity">عدد الأسياخ</label>
                                                <input type="number" id="add-iron-quantity" name="quantity" step="1" required placeholder="مثال: 150">
                                            </div>
                                            <div class="form-group">
                                                <label for="add-iron-notes">نوع الحديد</label>
                                                <input type="text" id="add-iron-notes" name="notes" required placeholder="مثال: حديد 16مم">
                                            </div>
                                        </div>
                                        <button type="submit" class="btn-submit">إضافة</button>
                                    </form>
                                    <form id="dispense-iron-form" class="material-form" style="display: none;">
                                        <h4>صرف عدد أسياخ</h4>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="dispense-iron-quantity">عدد الأسياخ</label>
                                                <input type="number" id="dispense-iron-quantity" name="quantity" step="1" required placeholder="مثال: 50">
                                            </div>
                                            <div class="form-group">
                                                <label for="dispense-iron-notes">سبب الصرف</label>
                                                <input type="text" id="dispense-iron-notes" name="notes" required placeholder="مثال: أعمدة الدور الأول">
                                            </div>
                                        </div>
                                        <button type="submit" class="btn-submit btn-dispense">صرف</button>
                                    </form>
                                </div>
                                <div class="admin-only" style="display: none;">
                                    <div class="log-section">
                                        <h4>سجل الإضافات</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>الكمية (سيخ)</th><th>المشرف</th><th>النوع</th></tr></thead>
                                                <tbody id="iron-add-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="iron-add-log-empty" class="log-empty">لا توجد سجلات إضافات.</p>
                                    </div>
                                    <div class="log-section">
                                        <h4>سجل الصرف</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>الكمية (سيخ)</th><th>المشرف</th><th>السبب</th></tr></thead>
                                                <tbody id="iron-dispense-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="iron-dispense-log-empty" class="log-empty">لا توجد سجلات صرف.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Cement Card -->
                        <div class="material-card" id="cement-card">
                            <div class="card-header">
                                <h3>الأسمنت (بالشكارة)</h3>
                                <div class="total-amount-display">
                                    <span>الكمية الحالية:</span>
                                    <span id="cement-total">جاري التحميل...</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="supervisor-only" style="display: none;">
                                    <div class="form-toggle-buttons">
                                        <button class="toggle-btn active" data-form="add-cement-form">إضافة كمية</button>
                                        <button class="toggle-btn" data-form="dispense-cement-form">صرف كمية</button>
                                    </div>
                                    <form id="add-cement-form" class="material-form">
                                        <h4>إضافة كمية جديدة</h4>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="add-cement-quantity">الكمية (شكارة)</label>
                                                <input type="number" id="add-cement-quantity" name="quantity" step="1" required placeholder="مثال: 50">
                                            </div>
                                            <div class="form-group">
                                                <label for="add-cement-notes">نوع الأسمنت</label>
                                                <input type="text" id="add-cement-notes" name="notes" required placeholder="مثال: أسمنت مقاوم">
                                            </div>
                                        </div>
                                        <button type="submit" class="btn-submit">إضافة</button>
                                    </form>
                                    <form id="dispense-cement-form" class="material-form" style="display: none;">
                                        <h4>صرف كمية مستخدمة</h4>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="dispense-cement-quantity">الكمية (شكارة)</label>
                                                <input type="number" id="dispense-cement-quantity" name="quantity" step="1" required placeholder="مثال: 10">
                                            </div>
                                            <div class="form-group">
                                                <label for="dispense-cement-notes">سبب الصرف</label>
                                                <input type="text" id="dispense-cement-notes" name="notes" required placeholder="مثال: صبة السقف">
                                            </div>
                                        </div>
                                        <button type="submit" class="btn-submit btn-dispense">صرف</button>
                                    </form>
                                </div>
                                <div class="admin-only" style="display: none;">
                                    <div class="log-section">
                                        <h4>سجل الإضافات</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>الكمية (شكارة)</th><th>المشرف</th><th>النوع</th></tr></thead>
                                                <tbody id="cement-add-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="cement-add-log-empty" class="log-empty">لا توجد سجلات إضافات.</p>
                                    </div>
                                    <div class="log-section">
                                        <h4>سجل الصرف</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>الكمية (شكارة)</th><th>المشرف</th><th>السبب</th></tr></thead>
                                                <tbody id="cement-dispense-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="cement-dispense-log-empty" class="log-empty">لا توجد سجلات صرف.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Other Card -->
                        <div class="material-card" id="other-card">
                            <div class="card-header">
                                <h3>أخرى</h3>
                                <div class="total-amount-display">
                                    <span>الكمية الحالية:</span>
                                    <span id="other-total">جاري التحميل...</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="supervisor-only" style="display: none;">
                                    <div class="form-toggle-buttons">
                                        <button class="toggle-btn active" data-form="add-other-form">إضافة كمية</button>
                                        <button class="toggle-btn" data-form="dispense-other-form">صرف كمية</button>
                                    </div>
                                    <form id="add-other-form" class="material-form">
                                        <h4>إضافة بند جديد</h4>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="add-other-quantity">الكمية</label>
                                                <input type="number" id="add-other-quantity" name="quantity" step="1" required placeholder="مثال: 10">
                                            </div>
                                            <div class="form-group">
                                                <label for="add-other-notes">وصف البند</label>
                                                <input type="text" id="add-other-notes" name="notes" required placeholder="مثال: براغي حجم 15سم">
                                            </div>
                                        </div>
                                        <button type="submit" class="btn-submit">إضافة</button>
                                    </form>
                                    <form id="dispense-other-form" class="material-form" style="display: none;">
                                        <h4>صرف بند</h4>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="dispense-other-quantity">الكمية المصروفة</label>
                                                <input type="number" id="dispense-other-quantity" name="quantity" step="1" required placeholder="مثال: 2">
                                            </div>
                                            <div class="form-group">
                                                <label for="dispense-other-notes">سبب الصرف</label>
                                                <input type="text" id="dispense-other-notes" name="notes" required placeholder="مثال: تركيب أبواب">
                                            </div>
                                        </div>
                                        <button type="submit" class="btn-submit btn-dispense">صرف</button>
                                    </form>
                                </div>
                                <div class="admin-only" style="display: none;">
                                   <div class="log-section">
                                        <h4>سجل الإضافات</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>الكمية</th><th>المشرف</th><th>الوصف</th></tr></thead>
                                                <tbody id="other-add-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="other-add-log-empty" class="log-empty">لا توجد سجلات إضافات.</p>
                                    </div>
                                    <div class="log-section">
                                        <h4>سجل الصرف</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>الكمية</th><th>المشرف</th><th>السبب</th></tr></thead>
                                                <tbody id="other-dispense-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="other-dispense-log-empty" class="log-empty">لا توجد سجلات صرف.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </section>
                </>
            ) : (
                <div class="error-card">
                    <h2>خطأ في تحميل البيانات</h2>
                    <p>تعذر العثور على المشروع المطلوب أو حدث خطأ أثناء تحميله. يرجى التأكد من صحة الرابط.</p>
                     <a href="/crs/projects" class="back-link">العودة إلى قائمة المشاريع</a>
                </div>
            )}
        </div>
    </main>
</Layout>

<script>
    import { initializeAuthCheck } from '../../../../scripts/auth/remains-auth.ts';
    import { db } from '../../../../firebase/client';
    import { collection, addDoc, query, where, onSnapshot, serverTimestamp, orderBy } from 'firebase/firestore';

    function setupMaterialSection(material, unit, projectId, user, userRole, isInteger = false) {
        const card = document.getElementById(`${material}-card`);
        if (!card) return;

        const totalEl = card.querySelector(`#${material}-total`);
        
        const addLogBodyEl = card.querySelector(`#${material}-add-log-body`);
        const dispenseLogBodyEl = card.querySelector(`#${material}-dispense-log-body`);
        const addLogEmptyEl = card.querySelector(`#${material}-add-log-empty`);
        const dispenseLogEmptyEl = card.querySelector(`#${material}-dispense-log-empty`);
        
        const addForm = card.querySelector(`#add-${material}-form`);
        const dispenseForm = card.querySelector(`#dispense-${material}-form`);
        const toggleButtons = card.querySelectorAll('.toggle-btn');

        toggleButtons.forEach(button => {
            button.addEventListener('click', (e) => {
                const parentCard = e.target.closest('.material-card');
                parentCard.querySelectorAll('.toggle-btn').forEach(btn => btn.classList.remove('active'));
                e.target.classList.add('active');
                
                const formId = e.target.dataset.form;
                parentCard.querySelectorAll('.material-form').forEach(form => {
                    form.style.display = form.id === formId ? 'block' : 'none';
                });
            });
        });

        const remainsQuery = query(
            collection(db, 'remains'),
            where("projectId", "==", projectId),
            where("material", "==", material),
            orderBy("createdAt", "desc")
        );

        onSnapshot(remainsQuery, (snapshot) => {
            let totalAmount = 0;
            const addLogEntries = [];
            const dispenseLogEntries = [];

            snapshot.forEach(doc => {
                const data = doc.data();
                totalAmount += data.quantity;
                if (data.quantity > 0) {
                    addLogEntries.push(data);
                } else if (data.quantity < 0) {
                    dispenseLogEntries.push(data);
                }
            });

            const displayAmount = isInteger ? totalAmount : totalAmount.toFixed(2);
            totalEl.textContent = `${displayAmount} ${unit}`;

            if (userRole === 'admin') {
                updateLogTable(addLogBodyEl, addLogEmptyEl, addLogEntries, false);
                updateLogTable(dispenseLogBodyEl, dispenseLogEmptyEl, dispenseLogEntries, true);
            }
        }, (error) => {
            console.error(`Error fetching ${material} data:`, error);
            totalEl.textContent = "خطأ";
        });

        if (userRole === 'supervisor') {
            setupFormSubmission(addForm, false, material, projectId, user, isInteger);
            setupFormSubmission(dispenseForm, true, material, projectId, user, isInteger);
        }
    }

    function updateLogTable(tbody, emptyMsg, entries, isDispenseLog) {
        if (!tbody || !emptyMsg) return;

        if (entries.length === 0) {
            emptyMsg.style.display = 'block';
            tbody.innerHTML = '';
        } else {
            emptyMsg.style.display = 'none';
            tbody.innerHTML = entries.map(entry => {
                const notesLabel = isDispenseLog ? (entry.material === 'iron' || entry.material === 'cement' ? 'السبب' : 'السبب') : (entry.material === 'iron' || entry.material === 'cement' ? 'النوع' : 'الوصف');
                return `
                <tr>
                    <td>${entry.createdAt?.toDate().toLocaleDateString('ar-EG') || ''}</td>
                    <td>${isDispenseLog ? Math.abs(entry.quantity) : entry.quantity}</td>
                    <td>${entry.supervisorName || '-'}</td>
                    <td>${entry.notes || '-'}</td>
                </tr>
            `}).join('');
        }
    }

    async function handleFormSubmit(e, isDispense, material, projectId, user, isInteger) {
        e.preventDefault();
        const form = e.target;
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalBtnText = submitBtn.textContent;

        submitBtn.disabled = true;
        submitBtn.textContent = 'جارٍ الحفظ...';

        try {
            let quantity = isInteger ? parseInt(form.quantity.value, 10) : parseFloat(form.quantity.value);
            if (isNaN(quantity) || quantity <= 0) throw new Error('يرجى إدخال كمية موجبة صحيحة.');
            
            if (isDispense) {
                quantity = -quantity;
            }

            await addDoc(collection(db, 'remains'), {
                projectId: projectId,
                material: material,
                quantity: quantity,
                notes: form.notes.value,
                supervisorId: user.uid,
                supervisorName: user.displayName || 'مشرف',
                createdAt: serverTimestamp()
            });

            form.reset();
            alert('تمت العملية بنجاح!');

        } catch (error) {
            console.error(`Error submitting ${material} form:`, error);
            alert(error.message || 'حدث خطأ أثناء الحفظ.');
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = originalBtnText;
        }
    }

    function setupFormSubmission(form, isDispense, material, projectId, user, isInteger) {
        if (form) {
            form.addEventListener('submit', (e) => handleFormSubmit(e, isDispense, material, projectId, user, isInteger));
        }
    }

    function initializeRemainsPage(user, userRole) {
        const pageContent = document.getElementById('page-content');
        if (!pageContent || !pageContent.dataset.projectExists) return;

        const projectId = pageContent.dataset.projectId;
        
        setupMaterialSection('iron', 'سيخ', projectId, user, userRole, true);
        setupMaterialSection('cement', 'شكارة', projectId, user, userRole, true);
        setupMaterialSection('other', 'وحدة', projectId, user, userRole, true);
    }

    initializeAuthCheck(initializeRemainsPage);

</script>

<style>
:root {
    --primary-color: #3b82f6;
    --secondary-color: #10b981;
    --danger-color: #ef4444;
    --border-color: #e9ecef;
    --card-shadow: 0 4px 15px rgba(0,0,0,0.06);
    --text-dark: #2d3748;
    --text-light: #6c757d;
    --bg-light: #f8f9fa;
    --bg-white: #ffffff;
}
.auth-container { display: flex; align-items: center; justify-content: center; min-height: 80vh; }
.remains-page { direction: rtl; font-family: 'Cairo', sans-serif; background-color: var(--bg-light); min-height: 100vh; padding: 2.5rem; }
.container { max-width: 1100px; margin: 0 auto; }

.page-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem; margin-bottom: 2.5rem; }
h1 { font-size: 2.25rem; font-weight: 800; color: var(--text-dark); }
.page-subtitle { color: var(--text-light); }
.back-link { color: var(--primary-color); font-weight: 600; text-decoration: none; padding: 0.6rem 1rem; background-color: #e7f3ff; border-radius: 8px; }

.error-card { background: var(--bg-white); border-radius: 12px; box-shadow: var(--card-shadow); padding: 4rem; text-align: center; border: 1px solid var(--border-color); }

.materials-section { display: grid; grid-template-columns: 1fr; gap: 2.5rem; }

@media (min-width: 1024px) {
    .materials-section { grid-template-columns: 1fr 1fr; }
}

.material-card { background-color: var(--bg-white); border-radius: 12px; box-shadow: var(--card-shadow); border: 1px solid var(--border-color); overflow: hidden; display: flex; flex-direction: column; }
.card-header { padding: 1.5rem; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; background-color: #fcfdff; }
.card-header h3 { font-size: 1.75rem; font-weight: 700; color: var(--text-dark); margin: 0; }
.total-amount-display span:first-child { color: var(--text-light); font-size: 1rem; }
.total-amount-display span:last-child { display: block; font-size: 1.5rem; font-weight: 700; color: var(--primary-color); }

.card-body { padding: 1.5rem; flex-grow: 1; }

.form-toggle-buttons { display: flex; border: 1px solid var(--border-color); border-radius: 8px; margin-bottom: 1.5rem; overflow: hidden; }
.toggle-btn { flex: 1; background-color: transparent; border: none; padding: .75rem; cursor: pointer; font-size: 1rem; font-weight: 600; color: var(--text-light); transition: background-color 0.2s, color 0.2s; }
.toggle-btn.active { background-color: var(--primary-color); color: white; }
.toggle-btn:not(.active):hover { background-color: #f1f5f9; }

.material-form { border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem; background-color: #fcfdff;}
.material-form h4 { font-size: 1.2rem; margin-top: 0; margin-bottom: 1.5rem; font-weight: 600;}
.form-row { display: flex; flex-wrap: wrap; gap: 1.5rem; margin-bottom: 1.5rem; }
.form-group { flex: 1; min-width: 200px; }
.form-group label { display: block; margin-bottom: .5rem; font-weight: 600; }
.form-group input { width: 100%; padding: .75rem; border: 1px solid #cbd5e1; border-radius: 8px; }

.btn-submit { background-color: var(--secondary-color); color: white; border: none; padding: .85rem 2.5rem; border-radius: 8px; cursor: pointer; font-size: 1rem; font-weight: 700; transition: background-color 0.2s; }
.btn-submit:hover { background-color: #059669; }
.btn-submit.btn-dispense { background-color: var(--danger-color); }
.btn-submit.btn-dispense:hover { background-color: #dc2626; }
.btn-submit:disabled { background-color: #9ca3af; cursor: not-allowed; }

.admin-only { display: flex; flex-direction: column; gap: 2rem; padding-top: 1rem; }
.log-section h4 { font-size: 1.2rem; margin-bottom: 1rem; font-weight: 600; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }
.table-container { overflow-x: auto; border: 1px solid var(--border-color); border-radius: 8px; }
table { width: 100%; border-collapse: collapse; text-align: center; }
thead { background-color: #f1f5f9; }
th, td { padding: 1rem; border-bottom: 1px solid var(--border-color); }
th { font-weight: 700; color: var(--text-dark); }
tbody tr:last-child td { border-bottom: none; }
tbody td { color: var(--text-light); }
.log-empty { display: none; text-align: center; padding: 1.5rem; color: var(--text-light); background-color: #f8f9fa; border-radius: 8px; }

</style>
