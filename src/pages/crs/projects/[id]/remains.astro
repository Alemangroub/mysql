---
import Layout from '../../../../layouts/Layout.astro';
import { db } from "../../../../firebase/admin";

export const prerender = false;

const { id } = Astro.params;
let project = null;

try {
    const projectDoc = await db.collection('projects').doc(id).get();
    if (projectDoc.exists) {
        const projectData = projectDoc.data();
        project = { 
            id: projectDoc.id, 
            projectName: projectData.projectName || 'اسم غير متوفر',
            supervisorIds: projectData.supervisorIds || [] 
        };
    } else {
       // Let the frontend handle the not found case
    }
} catch (error) {
    console.error("Error fetching project data in remains.astro:", error);
    project = null;
}

---

<Layout title={`بواقي مشروع: ${project ? project.projectName : 'غير متوفر'}`}>
    <div id="auth-loading-message" class="auth-container">
        <p>جارٍ التحقق من صلاحيات الدخول...</p>
    </div>

    <main 
        id="page-content" 
        class="remains-page" 
        style="display: none;" 
        data-project-id={project?.id}
        data-project-exists={project !== null}
        data-supervisor-ids={JSON.stringify(project?.supervisorIds || [])}
    >
         <div class="container">
            {project ? (
                <>
                    <header class="page-header">
                        <div>
                            <h1>بواقي مشروع: {project.projectName}</h1>
                            <p class="page-subtitle">صفحة مخصصة لإدارة البواقي للمشرف والأدمن.</p>
                        </div>
                        <a href={`/crs/projects/${id}`} class="back-link">&larr; العودة لتفاصيل المشروع</a>
                    </header>

                    <section class="materials-section">
                        <!-- Iron Card -->
                        <div class="material-card" id="iron-card">
                            <div class="card-header">
                                <h3>الحديد (بالطن)</h3>
                                <div class="total-amount-display">
                                    <span>الكمية الحالية:</span>
                                    <span id="iron-total">جاري التحميل...</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <form id="add-iron-form" class="supervisor-only" style="display: none;">
                                    <h4>إضافة كمية جديدة</h4>
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label for="iron-quantity">الكمية (بالطن)</label>
                                            <input type="number" id="iron-quantity" name="quantity" step="0.01" required placeholder="مثال: 1.5">
                                        </div>
                                        <div class="form-group">
                                            <label for="iron-notes">ملاحظات</label>
                                            <input type="text" id="iron-notes" name="notes" placeholder="اختياري">
                                        </div>
                                    </div>
                                    <button type="submit" class="btn-submit">إضافة</button>
                                </form>
                                <div id="iron-log" class="admin-only" style="display: none;">
                                    <h4>سجل الإضافات</h4>
                                    <div class="table-container">
                                        <table>
                                            <thead><tr><th>التاريخ</th><th>الكمية (طن)</th><th>المشرف</th><th>ملاحظات</th></tr></thead>
                                            <tbody id="iron-log-body"></tbody>
                                        </table>
                                    </div>
                                    <p id="iron-log-empty" style="display: none; text-align: center; padding: 1rem;">لا توجد سجلات.</p>
                                </div>
                            </div>
                        </div>

                        <!-- Cement Card -->
                        <div class="material-card" id="cement-card">
                            <div class="card-header">
                                <h3>الأسمنت (بالكيس)</h3>
                                <div class="total-amount-display">
                                    <span>الكمية الحالية:</span>
                                    <span id="cement-total">جاري التحميل...</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <form id="add-cement-form" class="supervisor-only" style="display: none;">
                                    <h4>إضافة كمية جديدة</h4>
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label for="cement-quantity">الكمية (كيس)</label>
                                            <input type="number" id="cement-quantity" name="quantity" step="1" required placeholder="مثال: 50">
                                        </div>
                                        <div class="form-group">
                                            <label for="cement-notes">ملاحظات</label>
                                            <input type="text" id="cement-notes" name="notes" placeholder="اختياري">
                                        </div>
                                    </div>
                                    <button type="submit" class="btn-submit">إضافة</button>
                                </form>
                                <div id="cement-log" class="admin-only" style="display: none;">
                                    <h4>سجل الإضافات</h4>
                                    <div class="table-container">
                                        <table>
                                            <thead><tr><th>التاريخ</th><th>الكمية (كيس)</th><th>المشرف</th><th>ملاحظات</th></tr></thead>
                                            <tbody id="cement-log-body"></tbody>
                                        </table>
                                    </div>
                                    <p id="cement-log-empty" style="display: none; text-align: center; padding: 1rem;">لا توجد سجلات.</p>
                                </div>
                            </div>
                        </div>

                         <!-- Other Card -->
                        <div class="material-card" id="other-card">
                            <div class="card-header">
                                <h3>أخرى</h3>
                                <div class="total-amount-display">
                                    <span>الكمية الحالية:</span>
                                    <span id="other-total">جاري التحميل...</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <form id="add-other-form" class="supervisor-only" style="display: none;">
                                    <h4>إضافة كمية جديدة</h4>
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label for="other-quantity">الكمية</label>
                                            <input type="number" id="other-quantity" name="quantity" step="1" required placeholder="مثال: 10">
                                        </div>
                                        <div class="form-group">
                                            <label for="other-notes">الوصف والملاحظات</label>
                                            <input type="text" id="other-notes" name="notes" placeholder="مثال: براغي حجم 15سم">
                                        </div>
                                    </div>
                                    <button type="submit" class="btn-submit">إضافة</button>
                                </form>
                                <div id="other-log" class="admin-only" style="display: none;">
                                    <h4>سجل الإضافات</h4>
                                    <div class="table-container">
                                        <table>
                                            <thead><tr><th>التاريخ</th><th>الكمية</th><th>المشرف</th><th>الوصف</th></tr></thead>
                                            <tbody id="other-log-body"></tbody>
                                        </table>
                                    </div>
                                    <p id="other-log-empty" style="display: none; text-align: center; padding: 1rem;">لا توجد سجلات.</p>
                                </div>
                            </div>
                        </div>

                    </section>
                </>
            ) : (
                <div class="error-card">
                    <h2>خطأ في تحميل البيانات</h2>
                    <p>تعذر العثور على المشروع المطلوب أو حدث خطأ أثناء تحميله. يرجى التأكد من صحة الرابط.</p>
                     <a href="/crs/projects" class="back-link">العودة إلى قائمة المشاريع</a>
                </div>
            )}
        </div>
    </main>
</Layout>

<script>
    import { initializeAuthCheck } from '../../../../scripts/auth/remains-auth.ts';
    import { db } from '../../../../firebase/client';
    import { collection, addDoc, query, where, onSnapshot, serverTimestamp, orderBy } from 'firebase/firestore';

    /**
     * Sets up the logic for a single material section (e.g., iron, cement).
     */
    function setupMaterialSection(material, unit, projectId, user, userRole) {
        const totalEl = document.getElementById(`${material}-total`);
        const logBodyEl = document.getElementById(`${material}-log-body`);
        const logEmptyEl = document.getElementById(`${material}-log-empty`);
        const addForm = document.getElementById(`add-${material}-form`);

        if (!totalEl) return; // Exit if the material card doesn't exist

        const remainsQuery = query(
            collection(db, 'remains'),
            where("projectId", "==", projectId),
            where("material", "==", material),
            orderBy("createdAt", "desc")
        );

        const unsubscribe = onSnapshot(remainsQuery, (snapshot) => {
            let totalAmount = 0;
            const logEntries = [];

            snapshot.forEach(doc => {
                const data = doc.data();
                totalAmount += data.quantity;
                logEntries.push(data);
            });

            totalEl.textContent = `${totalAmount} ${unit}`;

            if (userRole === 'admin' && logBodyEl && logEmptyEl) {
                if (logEntries.length === 0) {
                    logEmptyEl.style.display = 'block';
                    logBodyEl.innerHTML = '';
                } else {
                    logEmptyEl.style.display = 'none';
                    logBodyEl.innerHTML = logEntries.map(entry => `
                        <tr>
                            <td>${entry.createdAt?.toDate().toLocaleDateString('ar-EG') || ''}</td>
                            <td>${entry.quantity}</td>
                            <td>${entry.supervisorName || '-'}</td>
                            <td>${entry.notes || '-'}</td>
                        </tr>
                    `).join('');
                }
            }
        }, (error) => {
            console.error(`Error fetching ${material} data:`, error);
            totalEl.textContent = "خطأ";
        });

        if (userRole === 'supervisor' && addForm) {
            addForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const submitBtn = e.target.querySelector('button[type="submit"]');
                submitBtn.disabled = true;
                submitBtn.textContent = 'جارٍ الإضافة...';

                try {
                    const quantity = parseFloat(e.target.quantity.value);
                    if (isNaN(quantity) || quantity <= 0) throw new Error('يرجى إدخال كمية صحيحة.');
                    
                    await addDoc(collection(db, 'remains'), {
                        projectId: projectId,
                        material: material,
                        quantity: quantity,
                        notes: e.target.notes.value || '',
                        supervisorId: user.uid,
                        supervisorName: user.displayName || 'مشرف',
                        createdAt: serverTimestamp()
                    });

                    e.target.reset();
                    alert('تمت الإضافة بنجاح!');

                } catch (error) {
                    console.error(`Error adding new ${material} quantity:`, error);
                    alert(error.message || 'حدث خطأ.');
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'إضافة';
                }
            });
        }
    }

    /**
     * Initializes all material sections on the page.
     */
    function initializeRemainsPage(user, userRole) {
        const pageContent = document.getElementById('page-content');
        if (!pageContent || !pageContent.dataset.projectExists) return;

        const projectId = pageContent.dataset.projectId;
        
        // Setup each material section
        setupMaterialSection('iron', 'طن', projectId, user, userRole);
        setupMaterialSection('cement', 'كيس', projectId, user, userRole);
        setupMaterialSection('other', 'وحدة', projectId, user, userRole);
    }

    initializeAuthCheck(initializeRemainsPage);

</script>

<style>
:root {
    --primary-color: #3b82f6; /* Blue */
    --secondary-color: #10b981; /* Green */
    --border-color: #e9ecef;
    --card-shadow: 0 4px 15px rgba(0,0,0,0.06);
    --text-dark: #2d3748;
    --text-light: #6c757d;
    --bg-light: #f8f9fa;
    --bg-white: #ffffff;
}
.auth-container { display: flex; align-items: center; justify-content: center; min-height: 80vh; }
.auth-container p { font-size: 1.2rem; color: var(--text-light); }

.remains-page { direction: rtl; font-family: 'Cairo', sans-serif; background-color: var(--bg-light); min-height: 100vh; padding: 2.5rem; }
.container { max-width: 1100px; margin: 0 auto; }

.page-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem; margin-bottom: 2.5rem; }
h1 { font-size: 2.25rem; font-weight: 800; color: var(--text-dark); }
.page-subtitle { color: var(--text-light); }
.back-link { color: var(--primary-color); font-weight: 600; text-decoration: none; padding: 0.6rem 1rem; background-color: #e7f3ff; border-radius: 8px; }

.error-card { background: var(--bg-white); border-radius: 12px; box-shadow: var(--card-shadow); padding: 4rem; text-align: center; border: 1px solid var(--border-color); }
.error-card h2 { color: #dc3545; }

.materials-section { display: grid; grid-template-columns: 1fr; gap: 2.5rem; }

@media (min-width: 1024px) {
    .materials-section {
        grid-template-columns: 1fr 1fr; /* Two columns on larger screens */
    }
}

.material-card {
    background-color: var(--bg-white);
    border-radius: 12px;
    box-shadow: var(--card-shadow);
    border: 1px solid var(--border-color);
    overflow: hidden; /* Ensures child elements conform to border radius */
    display: flex;
    flex-direction: column;
}

.card-header {
    padding: 1.5rem;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: #fcfdff;
}

.card-header h3 { font-size: 1.75rem; font-weight: 700; color: var(--text-dark); margin: 0; }

.total-amount-display { text-align: left; }
.total-amount-display span:first-child { color: var(--text-light); font-size: 1rem; }
.total-amount-display span:last-child { display: block; font-size: 1.5rem; font-weight: 700; color: var(--primary-color); }

.card-body { padding: 1.5rem; flex-grow: 1; }

/* Form Styles */
form h4 { font-size: 1.2rem; margin-top: 0; margin-bottom: 1.5rem; font-weight: 600; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-color);}
.form-row { display: flex; flex-wrap: wrap; gap: 1.5rem; margin-bottom: 1.5rem; }
.form-group { flex: 1; min-width: 200px; }
.form-group label { display: block; margin-bottom: .5rem; font-weight: 600; }
.form-group input { width: 100%; padding: .75rem; border: 1px solid #cbd5e1; border-radius: 8px; transition: border-color 0.2s, box-shadow 0.2s; }
.form-group input:focus { outline: none; border-color: var(--primary-color); box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.3); }

.btn-submit {
    background-color: var(--primary-color);
    color: white;
    border: none;
    padding: .85rem 2.5rem;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 700;
    transition: background-color 0.2s, transform 0.1s;
}
.btn-submit:hover { background-color: #2563eb; transform: translateY(-1px); }
.btn-submit:disabled { background-color: #93c5fd; cursor: not-allowed; }

/* Admin Log Styles */
.admin-only h4 { font-size: 1.2rem; margin-top: 0; margin-bottom: 1rem; font-weight: 600; }
.table-container { overflow-x: auto; border: 1px solid var(--border-color); border-radius: 8px; }

table {
    width: 100%;
    border-collapse: collapse;
    text-align: center;
}

thead {
    background-color: #f1f5f9;
}

th, td {
    padding: 1rem;
    border-bottom: 1px solid var(--border-color);
}

th { font-weight: 700; color: var(--text-dark); }

tbody tr:last-child td { border-bottom: none; }
tbody td { color: var(--text-light); }

</style>