rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---
    // Helper Functions
    // ---

    function isUserAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isUserRole(role) {
      return isUserAuthenticated() && getUserRole() == role;
    }

    function isProjectSupervisor(projectId) {
      let projectData = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isUserAuthenticated() && request.auth.uid in projectData.supervisorIds;
    }

    // ---
    // Collection Rules
    // ---

    // Projects Collection
    match /projects/{projectId} {
      allow read: if isUserRole('admin') || (isUserRole('supervisor') && request.auth.uid in resource.data.supervisorIds);
      allow write: if isUserRole('admin');
      match /items/{itemId} { allow read, write, delete: if isUserRole('admin'); }
      match /imports/{importId} { allow read, write, delete: if isUserRole('admin'); }
      match /agreements/{agreementId} { allow read, write, delete: if isUserRole('admin'); }
    }

    // Remains Collection (UPDATED)
    match /remains/{remainId} {
      // Admins can read everything. Supervisors can only read entries for their own projects.
      allow read: if isUserRole('admin') || isProjectSupervisor(resource.data.projectId);

      // Admins can write anything. Supervisors can write to projects they are assigned to.
      // This covers create, update, and delete.
      allow write: if isUserRole('admin') || isProjectSupervisor(request.resource.data.projectId);
    }

    // Daily Expenses: Supervisors with the correct role can create, Admins can manage.
    match /daily_expenses/{expenseId} {
      allow create: if isUserRole('supervisor');
      allow read, update, delete: if isUserRole('admin');
    }

    // Daily Reports: Supervisors with the correct role can create, Admins can manage.
    match /daily_reports/{reportId} {
      allow create: if isUserRole('supervisor');
      allow read, update, delete: if isUserRole('admin');
    }

    // Users: Admins can manage users, users can read their own data.
    match /users/{userId} {
       allow read, write: if isUserRole('admin');
       allow get: if isUserAuthenticated() && request.auth.uid == userId;
    }

    // Contracts & Installments: Only Admins have access.
    match /contracts/{contractId} { allow read, write, delete: if isUserRole('admin'); }
    match /installments/{installmentId} { allow read, write, delete: if isUserRole('admin'); }
  }
}
